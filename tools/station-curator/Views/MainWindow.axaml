<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:img="clr-namespace:OrgZ.Converters;assembly=OrgZ"
        x:Class="OrgZ.StationCurator.Views.MainWindow"
        x:CompileBindings="False"
        Title="OrgZ Station Curator"
        Width="1600" Height="940"
        MinWidth="1200" MinHeight="720"
        WindowStartupLocation="CenterScreen">

	<Window.Styles>
		<Style Selector="TextBlock.label">
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="Margin" Value="8,0,4,0" />
			<Setter Property="Opacity" Value="0.7" />
		</Style>
		<Style Selector="TextBlock.sectionHeader">
			<Setter Property="FontSize" Value="11" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="Opacity" Value="0.55" />
			<Setter Property="LetterSpacing" Value="2" />
			<Setter Property="Margin" Value="2,0,0,8" />
		</Style>
		<Style Selector="Border.card">
			<Setter Property="Background" Value="#12FFFFFF" />
			<Setter Property="BorderBrush" Value="#28FFFFFF" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="CornerRadius" Value="6" />
			<Setter Property="Padding" Value="10" />
		</Style>
		<Style Selector="Border.inset">
			<Setter Property="Background" Value="#30000000" />
			<Setter Property="BorderBrush" Value="#20FFFFFF" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="CornerRadius" Value="6" />
			<Setter Property="Padding" Value="10" />
		</Style>
		<Style Selector="DataGrid">
			<Setter Property="GridLinesVisibility" Value="Horizontal" />
			<Setter Property="IsReadOnly" Value="True" />
			<Setter Property="CanUserResizeColumns" Value="True" />
		</Style>
		<!-- Same as the main app's grouped views: headers read "Synthwave (12 Items)" - the
		     grouping property's name ("GenreName:") is plumbing, not information. -->
		<Style Selector="DataGridRowGroupHeader">
			<Setter Property="IsPropertyNameVisible" Value="False" />
			<Setter Property="IsItemCountVisible" Value="True" />
		</Style>
		<!-- Genre headers are separators, not toggles: the chevron is the only tap target that
		     collapses a group, so hiding it makes headers inert. The code-behind re-expands
		     anything that still finds a way to fold (keyboard arrows on a focused header). -->
		<Style Selector="DataGridRowGroupHeader /template/ ToggleButton#PART_ExpanderButton">
			<Setter Property="IsVisible" Value="False" />
		</Style>
		<Style Selector="WrapPanel > TextBox, WrapPanel > ComboBox, WrapPanel > Button">
			<Setter Property="Margin" Value="0,2,6,2" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>
	</Window.Styles>

	<DockPanel>

		<!-- Toolbar -->
		<Border DockPanel.Dock="Top" Padding="8,6" Background="#22000000">
			<DockPanel>
				<StackPanel Orientation="Horizontal" Spacing="6">
					<Button Content="Save" Command="{Binding SaveStoreCommand}" />
					<Button Content="Export stations.json" Command="{Binding ExportStationsCommand}" />
					<Button Content="Probe All" Command="{Binding ProbeAllCommand}" />
				</StackPanel>
				<StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
					<TextBlock Text="{Binding StoreSummary}" VerticalAlignment="Center" Opacity="0.7" />
				</StackPanel>
				<StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
					<Button Content="Play" Command="{Binding PlayCommand}" />
					<Button Content="Stop" Command="{Binding StopPlaybackCommand}" />
					<TextBlock Text="{Binding NowPlaying}" VerticalAlignment="Center" FontWeight="Bold" />
				</StackPanel>
			</DockPanel>
		</Border>

		<!-- Status bar -->
		<Border DockPanel.Dock="Bottom" Padding="8,4" Background="#22000000">
			<DockPanel>
				<ProgressBar DockPanel.Dock="Right" Width="120" IsIndeterminate="True" IsVisible="{Binding IsBusy}" />
				<TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" />
			</DockPanel>
		</Border>

		<Grid ColumnDefinitions="5*,8,6*" Margin="8">

			<!-- ============ Sources ============ -->
			<Border Grid.Column="0" Classes="card">
			<DockPanel>
				<TextBlock DockPanel.Dock="Top" Classes="sectionHeader" Text="SOURCES" />

				<TabControl DockPanel.Dock="Top" SelectedIndex="{Binding SourceTabIndex}">
					<TabItem Header="Radio Browser">
						<WrapPanel Margin="0,4">
							<TextBlock Classes="label" Text="Name" />
							<TextBox x:Name="RbNameBox" Width="130" Text="{Binding RbName}" />
							<TextBlock Classes="label" Text="Tag" />
							<TextBox x:Name="RbTagBox" Width="120" Text="{Binding RbTag}" />
							<TextBlock Classes="label" Text="Country" />
							<TextBox Width="110" Text="{Binding RbCountry}" />
							<TextBlock Classes="label" Text="Order" />
							<ComboBox ItemsSource="{Binding RbOrders}" SelectedItem="{Binding RbOrder}" />
							<ComboBox ItemsSource="{Binding RbLimits}" SelectedItem="{Binding RbLimit}" />
							<Button x:Name="RbSearchButton" Content="Search" Command="{Binding SearchRadioBrowserCommand}" />
						</WrapPanel>
					</TabItem>
					<TabItem Header="SHOUTcast">
						<WrapPanel Margin="0,4">
							<Button Content="Top Stations" Command="{Binding ShoutcastTopCommand}" />
							<TextBlock Classes="label" Text="Genre" />
							<TextBox Width="140" Text="{Binding ScGenre}" />
							<Button Content="Browse" Command="{Binding ShoutcastGenreCommand}" />
							<TextBlock Classes="label" Text="Search" />
							<TextBox Width="160" Text="{Binding ScQuery}" />
							<Button Content="Go" Command="{Binding ShoutcastSearchCommand}" />
						</WrapPanel>
					</TabItem>
					<TabItem Header="Icecast">
						<WrapPanel Margin="0,4">
							<TextBlock Classes="label" Text="Server" />
							<TextBox Width="320" Text="{Binding IcecastUrl}" />
							<Button Content="Fetch Mounts" Command="{Binding FetchIcecastCommand}" />
						</WrapPanel>
					</TabItem>
				</TabControl>

				<StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
					<TextBlock Classes="label" Text="Genre" />
					<ComboBox Width="170" ItemsSource="{Binding ImportGenreChoices}" SelectedItem="{Binding ImportGenre}" />
					<Button Content="Import Selected" Command="{Binding ImportSelectedCommand}" />
					<Button Content="Add Station (Auto Genre)" Command="{Binding ImportSelectedAutoCommand}" />
					<Button Content="Show in Curated" Command="{Binding JumpToCuratedCommand}" />
				</StackPanel>

				<!-- Source detail / pre-import probe -->
				<Border DockPanel.Dock="Bottom" Classes="inset" Margin="0,10,0,0"
				        IsVisible="{Binding SelectedSource, Converter={x:Static ObjectConverters.IsNotNull}}">
					<DockPanel>
					<TextBlock DockPanel.Dock="Top" Classes="sectionHeader" Text="SOURCE" />
					<Grid ColumnDefinitions="Auto,12,*" RowDefinitions="Auto,8,Auto">

						<Image Grid.Column="0" Grid.Row="0" Width="96" Height="96" Stretch="Uniform"
						       VerticalAlignment="Top"
						       img:RemoteImage.Url="{Binding SelectedSource.LogoUrl}" />

						<Grid Grid.Column="2" Grid.Row="0"
						      ColumnDefinitions="Auto,6,2*,16,Auto,6,*"
						      RowDefinitions="Auto,6,Auto,6,Auto,6,Auto,6,Auto">
							<TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Name" />
							<TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding SelectedSource.Name}" />
							<TextBlock Grid.Row="0" Grid.Column="4" Classes="label" Text="Country" />
							<Image Grid.Row="0" Grid.Column="6" Width="24" Height="16" Stretch="Uniform"
							       VerticalAlignment="Center" HorizontalAlignment="Left"
							       ToolTip.Tip="{Binding SelectedSource.Country}"
							       Source="{Binding SelectedSource.CountryCode, Converter={x:Static img:CountryCodeToFlagConverter.Instance}}" />

							<TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Tags" />
							<TextBlock Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding SelectedSource.Tags}" />

							<TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="URL" />
							<SelectableTextBlock Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding SelectedSource.StreamUrl}" />

							<TextBlock Grid.Row="6" Grid.Column="0" Classes="label" Text="Home" />
							<SelectableTextBlock Grid.Row="6" Grid.Column="2" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding SelectedSource.HomeLabel}" />
							<TextBlock Grid.Row="6" Grid.Column="4" Classes="label" Text="Logo" />
							<SelectableTextBlock Grid.Row="6" Grid.Column="6" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding SelectedSource.LogoLabel}" />

							<TextBlock Grid.Row="8" Grid.Column="0" Classes="label" Text="Server" />
							<SelectableTextBlock Grid.Row="8" Grid.Column="2" Grid.ColumnSpan="5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding SelectedSource.ServerInfoLabel}" />
						</Grid>

						<DockPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2">
							<StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
								<Button Content="Probe" Command="{Binding ProbeSourceCommand}" />
							</StackPanel>
							<DataGrid ItemsSource="{Binding SourceProbeRows}" MaxHeight="80">
								<DataGrid.Columns>
									<DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="2*" />
									<DataGridTextColumn Header="Fmt" Binding="{Binding EffectiveFormat}" Width="Auto" />
									<DataGridTextColumn Header="kbps" Binding="{Binding EffectiveBitrate}" Width="Auto" />
									<DataGridTextColumn Header="Hops" Binding="{Binding HopsLabel}" Width="Auto" />
										<DataGridTextColumn Header="Tune" Binding="{Binding TuneInLabel}" Width="Auto" />
									<DataGridTextColumn Header="Meta" Binding="{Binding MetadataLabel}" Width="Auto" />
									<DataGridTextColumn Header="Match" Binding="{Binding MatchLabel}" Width="Auto" />
									<DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="Auto" />
									<DataGridTextColumn Header="Probe" Binding="{Binding ProbeLabel}" Width="Auto" />
									<DataGridTemplateColumn Header="Geo" Width="56">
										<DataGridTemplateColumn.CellTemplate>
											<DataTemplate>
												<StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip.Tip="{Binding ServerCountry}">
													<Image Width="24" Height="16" Stretch="Uniform" Source="{Binding ServerCountryCode, Converter={x:Static img:CountryCodeToFlagConverter.Instance}}" />
													<TextBlock Text="⚠" VerticalAlignment="Center" IsVisible="{Binding GeoRisk}" />
												</StackPanel>
											</DataTemplate>
										</DataGridTemplateColumn.CellTemplate>
									</DataGridTemplateColumn>
									<DataGridTextColumn Header="Detail" Binding="{Binding ProbeDetail}" Width="*" />
								</DataGrid.Columns>
							</DataGrid>
						</DockPanel>
					</Grid>
					</DockPanel>
				</Border>

				<DataGrid x:Name="SourceGrid"
				          ItemsSource="{Binding SourceResults}"
				          SelectedItem="{Binding SelectedSource}"
				          SelectionMode="Extended">
					<DataGrid.Columns>
						<DataGridTextColumn Header="" Binding="{Binding CuratedMark}" Width="Auto" />
						<DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
						<DataGridTextColumn Header="Tags" Binding="{Binding Tags}" Width="*" />
						<DataGridTextColumn Header="Suggested" Binding="{Binding SuggestedGenreName}" Width="Auto" />
						<DataGridTextColumn Header="Fmt" Binding="{Binding Format}" Width="Auto" />
						<DataGridTextColumn Header="kbps" Binding="{Binding Bitrate}" Width="Auto" />
						<DataGridTemplateColumn Header="Country" Width="60">
							<DataGridTemplateColumn.CellTemplate>
								<DataTemplate>
									<Image Width="24" Height="16" Stretch="Uniform"
									       HorizontalAlignment="Center" VerticalAlignment="Center"
									       Source="{Binding CountryCode, Converter={x:Static img:CountryCodeToFlagConverter.Instance}}"
									       ToolTip.Tip="{Binding Country}" />
								</DataTemplate>
							</DataGridTemplateColumn.CellTemplate>
						</DataGridTemplateColumn>
						<DataGridTextColumn Header="Pop" Binding="{Binding Popularity}" Width="Auto" />
					</DataGrid.Columns>
				</DataGrid>
			</DockPanel>
			</Border>

			<GridSplitter Grid.Column="1" Background="Transparent" ResizeDirection="Columns" />

			<!-- ============ Curated ============ -->
			<Border Grid.Column="2" Classes="card">
			<DockPanel>
				<TextBlock DockPanel.Dock="Top" Classes="sectionHeader" Text="CURATED" />

				<StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
					<TextBlock Classes="label" Text="Genre" />
					<ComboBox Width="160" ItemsSource="{Binding CuratedFilterChoices}" SelectedItem="{Binding CuratedFilterGenre}" />
					<TextBlock Classes="label" Text="Search" />
					<TextBox Width="180" Text="{Binding CuratedSearch}" />
					<Button Content="New Station" Command="{Binding NewStationCommand}" />
					<Button Content="Remove Station" Command="{Binding RemoveStationCommand}" />
					<Button Content="Probe Station" Command="{Binding ProbeStationCommand}" />
				</StackPanel>

				<!-- Detail / variants -->
				<Border DockPanel.Dock="Bottom" Classes="inset" Margin="0,10,0,0"
				        IsVisible="{Binding SelectedCurated, Converter={x:Static ObjectConverters.IsNotNull}}">
					<DockPanel>
					<TextBlock DockPanel.Dock="Top" Classes="sectionHeader" Text="STATION" />
					<Grid ColumnDefinitions="Auto,12,*" RowDefinitions="Auto,8,Auto">

						<Image Grid.Column="0" Grid.Row="0" Width="96" Height="96" Stretch="Uniform"
						       VerticalAlignment="Top"
						       img:RemoteImage.Url="{Binding SelectedCurated.LogoUrl}" />

						<Grid Grid.Column="2" Grid.Row="0"
						      ColumnDefinitions="Auto,6,2*,16,Auto,6,*,16,Auto,6,Auto"
						      RowDefinitions="Auto,6,Auto,6,Auto">
							<TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Name" />
							<TextBox Grid.Row="0" Grid.Column="2" Text="{Binding SelectedCurated.Name}" />
							<TextBlock Grid.Row="0" Grid.Column="4" Classes="label" Text="Genre" />
							<ComboBox Grid.Row="0" Grid.Column="6" ItemsSource="{Binding DetailGenreChoices}" SelectedItem="{Binding SelectedCuratedGenreName}" />
							<TextBlock Grid.Row="0" Grid.Column="8" Classes="label" Text="Country" />
							<StackPanel Grid.Row="0" Grid.Column="10" Orientation="Horizontal" Spacing="4">
								<Image Width="24" Height="16" Stretch="Uniform" VerticalAlignment="Center"
								       Source="{Binding SelectedCurated.CountryCode, Converter={x:Static img:CountryCodeToFlagConverter.Instance}}" />
								<TextBox Width="130" Text="{Binding SelectedCurated.Country}" />
								<TextBox Width="44" Text="{Binding SelectedCurated.CountryCode}" />
								<Button Content="Use GeoIP" Command="{Binding UseGeoIpCountryCommand}" />
							</StackPanel>

							<TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Home" />
							<TextBox Grid.Row="2" Grid.Column="2" Text="{Binding SelectedCurated.Homepage}" />
							<TextBlock Grid.Row="2" Grid.Column="4" Classes="label" Text="Logo" />
							<TextBox Grid.Row="2" Grid.Column="6" Grid.ColumnSpan="5" Text="{Binding SelectedCurated.LogoUrl}" />

							<TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="Notes" />
							<TextBox Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="9" Text="{Binding SelectedCurated.Notes}" />
						</Grid>

						<DockPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2">
							<StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
								<Button Content="Probe" Command="{Binding ProbeVariantCommand}" />
								<Button Content="Prefer" Command="{Binding SetPreferredVariantCommand}" />
								<Button Content="Remove Stream" Command="{Binding RemoveVariantCommand}" />
								<TextBlock Classes="label" Text="Add URL" />
								<TextBox Width="260" VerticalAlignment="Center" Text="{Binding NewStreamUrl}" />
								<Button Content="Add Stream" Command="{Binding AddStreamCommand}" />
							</StackPanel>
							<DataGrid ItemsSource="{Binding Variants}"
							          SelectedItem="{Binding SelectedVariant}"
							          MaxHeight="170">
								<DataGrid.Columns>
									<DataGridTextColumn Header="" Binding="{Binding PreferredMark}" Width="Auto" />
									<DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="2*" />
									<DataGridTextColumn Header="Fmt" Binding="{Binding EffectiveFormat}" Width="Auto" />
									<DataGridTextColumn Header="kbps" Binding="{Binding EffectiveBitrate}" Width="Auto" />
									<DataGridTextColumn Header="Hops" Binding="{Binding HopsLabel}" Width="Auto" />
										<DataGridTextColumn Header="Tune" Binding="{Binding TuneInLabel}" Width="Auto" />
									<DataGridTextColumn Header="Meta" Binding="{Binding MetadataLabel}" Width="Auto" />
									<DataGridTextColumn Header="Match" Binding="{Binding MatchLabel}" Width="Auto" />
									<DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="Auto" />
									<DataGridTextColumn Header="Probe" Binding="{Binding ProbeLabel}" Width="Auto" />
									<DataGridTemplateColumn Header="Geo" Width="56">
										<DataGridTemplateColumn.CellTemplate>
											<DataTemplate>
												<StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip.Tip="{Binding ServerCountry}">
													<Image Width="24" Height="16" Stretch="Uniform" Source="{Binding ServerCountryCode, Converter={x:Static img:CountryCodeToFlagConverter.Instance}}" />
													<TextBlock Text="⚠" VerticalAlignment="Center" IsVisible="{Binding GeoRisk}" />
												</StackPanel>
											</DataTemplate>
										</DataGridTemplateColumn.CellTemplate>
									</DataGridTemplateColumn>
									<DataGridTextColumn Header="Detail" Binding="{Binding ProbeDetail}" Width="*" />
								</DataGrid.Columns>
							</DataGrid>
						</DockPanel>
					</Grid>
					</DockPanel>
				</Border>

				<DataGrid x:Name="CuratedGrid"
				          ItemsSource="{Binding CuratedView}"
				          SelectedItem="{Binding SelectedCurated}"
				          LoadingRow="OnCuratedRowLoading">
					<DataGrid.Columns>
						<DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
						<DataGridTemplateColumn Header="Country" Width="60">
							<DataGridTemplateColumn.CellTemplate>
								<DataTemplate>
									<Image Width="24" Height="16" Stretch="Uniform"
									       HorizontalAlignment="Center" VerticalAlignment="Center"
									       Source="{Binding CountryCode, Converter={x:Static img:CountryCodeToFlagConverter.Instance}}"
									       ToolTip.Tip="{Binding Country}" />
								</DataTemplate>
							</DataGridTemplateColumn.CellTemplate>
						</DataGridTemplateColumn>
						<DataGridTextColumn Header="Streams" Binding="{Binding StreamCount}" Width="Auto" />
						<DataGridTextColumn Header="Codec" Binding="{Binding BestFormat}" Width="Auto" />
						<DataGridTextColumn Header="Best" Binding="{Binding BestBitrate}" Width="Auto" />
						<DataGridTextColumn Header="Meta" Binding="{Binding MetaLabel}" Width="Auto" />
						<DataGridTextColumn Header="Icon" Binding="{Binding IconLabel}" Width="Auto" />
						<DataGridTextColumn Header="Probe" Binding="{Binding ProbeSummary}" Width="Auto" />
						<DataGridTemplateColumn Header="Geo" Width="56">
							<DataGridTemplateColumn.CellTemplate>
								<DataTemplate>
									<StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip.Tip="{Binding GeoCountry}">
										<Image Width="24" Height="16" Stretch="Uniform" Source="{Binding GeoCountryCode, Converter={x:Static img:CountryCodeToFlagConverter.Instance}}" />
										<TextBlock Text="⚠" VerticalAlignment="Center" IsVisible="{Binding AnyGeoRisk}" />
									</StackPanel>
								</DataTemplate>
							</DataGridTemplateColumn.CellTemplate>
						</DataGridTemplateColumn>
					</DataGrid.Columns>
				</DataGrid>
			</DockPanel>
			</Border>
		</Grid>
	</DockPanel>
</Window>
