<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:i="https://github.com/projektanker/icons.avalonia"
		xmlns:controls="using:OrgZ.Controls"
		mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="450"
		x:Class="OrgZ.Views.MainWindow"
		Title="OrgZ"
		Width="1100" Height="700"
		MinWidth="1080" MinHeight="500"
		x:CompileBindings="False">

	<NativeMenu.Menu>
		<NativeMenu>
			<NativeMenuItem Header="File">
				<NativeMenu>
					<NativeMenuItem Header="Change Library Folder..." Command="{Binding ChangeLibraryFolderCommand}" />
					<NativeMenuItemSeparator />
					<NativeMenuItem Header="Import Playlist..." Command="{Binding ImportPlaylistCommand}" />
					<NativeMenuItem Header="Export Library..." IsEnabled="False" />
					<NativeMenuItemSeparator />
					<NativeMenuItem Header="Settings..." Command="{Binding ShowSettingsCommand}" />
					<NativeMenuItemSeparator />
					<NativeMenuItem Header="Exit" Command="{Binding ExitApplicationCommand}" Gesture="Ctrl+Q" />
				</NativeMenu>
			</NativeMenuItem>
			<NativeMenuItem Header="Playback">
				<NativeMenu>
					<NativeMenuItem Header="Play / Pause" Command="{Binding ButtonPlayPauseCommand}" />
					<NativeMenuItem Header="Previous Track" Command="{Binding ButtonPreviousTrackCommand}" Gesture="Ctrl+Left" />
					<NativeMenuItem Header="Next Track" Command="{Binding ButtonNextTrackCommand}" Gesture="Ctrl+Right" />
				</NativeMenu>
			</NativeMenuItem>
			<NativeMenuItem Header="Window">
				<NativeMenu>
					<NativeMenuItem Header="Switch to Mini-Player" Command="{Binding ToggleMiniPlayerCommand}" Gesture="Alt+Shift+M" />
					<NativeMenuItem Header="Show Full Player" Command="{Binding ShowMainWindowCommand}" Gesture="Alt+Shift+F" />
				</NativeMenu>
			</NativeMenuItem>
			<NativeMenuItem Header="Help">
				<NativeMenu>
					<NativeMenuItem Header="About OrgZ" Command="{Binding ShowAboutCommand}" />
				</NativeMenu>
			</NativeMenuItem>
		</NativeMenu>
	</NativeMenu.Menu>

	<Window.Styles>
		<Style Selector="Button">
			<Setter Property="Background" Value="{DynamicResource SystemChromeGrayColor}"/>
		</Style>

		<Style Selector="Slider:horizontal">
			<Setter Property="MinHeight" Value="14" />
			<Setter Property="Margin" Value="0,-2,0,0" />
			<Setter Property="Padding" Value="0" />

			<!-- Filled track (left of thumb) -->
			<Setter Property="Foreground" Value="{StaticResource OrgZLcdProgressBrush}" />

			<!-- Empty track background -->
			<Setter Property="Background" Value="{StaticResource OrgZLcdRimBrush}" />

			<Style Selector="^ Track">
				<Setter Property="Height" Value="14" />
				<Setter Property="Margin" Value="0" />

				<!-- Playback head -->
				<Style Selector="^ Thumb">
					<Setter Property="Width" Value="14" />
					<Setter Property="Height" Value="14" />
					<Setter Property="CornerRadius" Value="0" />
					<Setter Property="Background" Value="{StaticResource OrgZLcdProgressBrush}" />
					<Setter Property="BorderBrush" Value="{StaticResource OrgZLcdTextBrush}" />
					<Setter Property="BorderThickness" Value="1" />
					<Setter Property="Margin" Value="0" />
					<Setter Property="Padding" Value="0" />
				</Style>
			</Style>
		</Style>

		<!-- GridSplitter style -->
		<Style Selector="GridSplitter">
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<Style Selector="GridSplitter:pointerover">
			<Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
			<Setter Property="Opacity" Value="0.3" />
		</Style>

		<!-- LCD-styled rip progress bar: forces the indicator fill to the dark
		     LCD green (Foreground alone doesn't pierce the FluentTheme template). -->
		<Style Selector="ProgressBar.lcdRip /template/ Border#PART_Indicator">
			<Setter Property="Background" Value="{StaticResource OrgZLcdProgressBrush}" />
		</Style>
		<Style Selector="ProgressBar.lcdRip">
			<Setter Property="MinHeight" Value="8" />
		</Style>

		<!-- The Slider.lcdSeek style itself lives in App/OrgZStyles.axaml so
		     the mini-player can reuse it too. -->
	</Window.Styles>

	<DockPanel>
		<DockPanel.Styles>
			<Style Selector="ContentPresenter, TextBlock, TextBox">
				<Setter Property="TextElement.FontFamily" Value="Consolas"/>
			</Style>
		</DockPanel.Styles>

		<NativeMenuBar DockPanel.Dock="Top" />

		<!-- Everything below menu gets the metal texture -->
		<Panel>
			<Panel.Background>
				<ImageBrush Source="avares://Orgz/Assets/metal.png" Opacity=".7" TileMode="Tile" Stretch="Fill" AlignmentX="Left" AlignmentY="Top" DestinationRect="0,0,128,128" />
			</Panel.Background>

		<DockPanel>

		<!-- Top controls row. Original column layout — play (Auto), spacer (*),
		     art (Auto), LCD (Auto), spacer (*), search (Auto). Spacers absorb
		     growth slack so play stays anchored left and search stays anchored
		     right. The LCD's Width is driven from code-behind via SizeChanged
		     so it can shrink between 380 and 588 as the window resizes, without
		     touching ColumnDefinition.MinWidth/MaxWidth (Avalonia 12's Grid
		     crashes during measure when a *-column carries both). -->
		<Grid DockPanel.Dock="Top" x:Name="TopControlsGrid" ColumnDefinitions="Auto,*,Auto,Auto,*,Auto">
				<Border Grid.Column="0" Margin="25,4,4,4">
					<StackPanel HorizontalAlignment="Center">
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5">
							<Button Command="{Binding ToggleShuffleCommand}" Background="Transparent" BorderThickness="0" Padding="4" VerticalAlignment="Center" Cursor="Hand" Width="32" Height="32">
								<i:Icon Value="{Binding ShuffleIcon}" FontSize="16" Opacity="{Binding ShuffleOpacity}" />
							</Button>
							<Button IsEnabled="{Binding IsBackTrackButtonEnabled}" Width="50" Height="50" FontSize="28" CornerRadius="100" VerticalAlignment="Center" i:Attached.Icon="fa-solid fa-backward-fast" Command="{Binding ButtonPreviousTrack}"></Button>
							<Button IsEnabled="{Binding IsButtonPlayPauseEnabled}" Width="64" Height="64" FontSize="42" CornerRadius="100" VerticalAlignment="Center" i:Attached.Icon="{Binding ButtonPlayPauseIcon}" Command="{Binding ButtonPlayPause}" Padding="{Binding ButtonPlayPausePadding}"></Button>
							<Button IsEnabled="{Binding IsNextTrackButtonEnabled}" Width="50" Height="50" FontSize="28" CornerRadius="100" VerticalAlignment="Center" i:Attached.Icon="fa-solid fa-forward-fast" Command="{Binding ButtonNextTrack}"></Button>
							<Button Command="{Binding CycleRepeatModeCommand}" Background="Transparent" BorderThickness="0" Padding="4" VerticalAlignment="Center" Cursor="Hand" Width="32" Height="32">
								<i:Icon Value="{Binding RepeatIcon}" FontSize="16" Opacity="{Binding RepeatOpacity}" />
							</Button>
						</StackPanel>
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,5">
							<Button Command="{Binding MuteVolumeCommand}" Background="Transparent" BorderThickness="0" Padding="2" Margin="0,0,5,0" VerticalAlignment="Center" Cursor="Hand">
								<i:Icon Value="fa-solid fa-volume-low" FontSize="16" />
							</Button>
							<Slider Minimum="0" Maximum="100" Value="{Binding CurrentVolume, Mode=TwoWay}" ValueChanged="Slider_ValueChanged" VerticalAlignment="Center" Width="80" Height="18" Padding="0,-9,0,0" />
							<Button Command="{Binding MaxVolumeCommand}" Background="Transparent" BorderThickness="0" Padding="2" Margin="5,0,0,0" VerticalAlignment="Center" Cursor="Hand">
								<i:Icon Value="fa-solid fa-volume-high" FontSize="16" />
							</Button>
						</StackPanel>
					</StackPanel>
				</Border>
				<Border Grid.Column="2" Margin="4" VerticalAlignment="Center" Cursor="Hand" PointerPressed="NowPlaying_PointerPressed">
					<!-- Outer chrome stays dark for the "no art" placeholder. When real art
					     is present a white inner backdrop renders behind it so transparent
					     PNGs / radio favicons don't blend into the dark theme. -->
					<Border Background="{DynamicResource SystemChromeGrayColor}" CornerRadius="6" Width="75" Height="75" ClipToBounds="True">
						<Panel>
							<Border Background="White" IsVisible="{Binding CurrentAlbumArt, Converter={x:Static ObjectConverters.IsNotNull}}">
								<Image Source="{Binding CurrentAlbumArt}" Stretch="UniformToFill" />
							</Border>
							<i:Icon Value="fa-solid fa-music" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding CurrentAlbumArt, Converter={x:Static ObjectConverters.IsNull}}" Opacity="0.4" />
						</Panel>
					</Border>
				</Border>
				<!-- LCD: click anywhere (except the seek slider) toggles between
				     track info and VU meter.  Double-click still navigates
				     to the playing track.  See MainLcd_PointerPressed. -->
				<Border Grid.Column="3" Margin="4" Cursor="Hand" PointerPressed="MainLcd_PointerPressed">
					<!-- LCD: Width is set in code-behind on Window.SizeChanged (see
					     UpdateLcdWidth). Default 588, shrinks down to MinWidth=380 when
					     the window can't fit everything at 588. The chevron / cancel
					     gutter (14px on each side, set on the inner Panel below) and the
					     content layers ride along. -->
					<controls:LcdDisplay x:Name="MainLcdPanel" Width="588" MinWidth="380" Height="75" />
				</Border>
				<Border Grid.Column="5" Margin="4,4,25,4">
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
						<!-- Audio output picker: mirrors the mini-player's speaker icon so
						     users can route audio to different output devices without
						     opening Settings. Flyout contents are populated on click by
						     AudioOutputFlyoutHelper. -->
						<Button x:Name="AudioOutputButton" Click="AudioOutputButton_Click" Background="Transparent" BorderThickness="0" Padding="4" Margin="10,10,2,10" VerticalAlignment="Center" Cursor="Hand" ToolTip.Tip="Audio output devices">
							<i:Icon Value="fa-solid fa-volume-high" FontSize="16" />
							<Button.Flyout>
								<Flyout Placement="BottomEdgeAlignedRight">
									<DockPanel MinWidth="320" MaxWidth="420" LastChildFill="True">
										<TextBlock DockPanel.Dock="Top" Text="Output Devices" FontWeight="Bold" FontSize="12" Margin="6,4,6,6" />
										<TextBlock DockPanel.Dock="Top" x:Name="AudioOutputFlyoutHint" Text="" Opacity="0.6" FontSize="10" Margin="6,0,6,6" />
										<StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="6,6,6,6" Spacing="6">
											<Button Content="Refresh" Click="AudioOutputRefresh_Click" FontSize="11" Padding="8,4" />
											<Button Content="Open Settings…" Click="AudioOutputOpenSettings_Click" FontSize="11" Padding="8,4" />
										</StackPanel>
										<ScrollViewer MaxHeight="300" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
											<StackPanel x:Name="AudioOutputDeviceList" Spacing="4" Margin="6,0,6,0" />
										</ScrollViewer>
									</DockPanel>
								</Flyout>
							</Button.Flyout>
						</Button>
						<Button Command="{Binding ToggleDrillDownCommand}" Background="Transparent" BorderThickness="0" Padding="4" Margin="2,10,2,10" VerticalAlignment="Center" Cursor="Hand" ToolTip.Tip="Browse by Artist">
							<i:Icon Value="fa-solid fa-folder-tree" FontSize="16" />
						</Button>
						<Button Command="{Binding ToggleQueueCommand}" Background="Transparent" BorderThickness="0" Padding="4" Margin="2,10,2,10" VerticalAlignment="Center" Cursor="Hand" ToolTip.Tip="Up Next">
							<i:Icon Value="fa-solid fa-list" FontSize="16" />
						</Button>
						<Button Command="{Binding ToggleActivityPanelCommand}" Background="Transparent" BorderThickness="0" Padding="4" Margin="2,10,5,10" VerticalAlignment="Center" Cursor="Hand" ToolTip.Tip="Activity" ClipToBounds="False">
							<Panel ClipToBounds="False">
								<!-- Static icon when idle; spinning gear while a rip / burn / sync
								     is in flight so the user gets visible feedback even with the
								     activity panel closed. -->
								<i:Icon Value="fa-solid fa-bars-progress" FontSize="16"
								        IsVisible="{Binding !HasActiveActivities}" />
								<i:Icon Value="fa-solid fa-gear" FontSize="16"
								        IsVisible="{Binding HasActiveActivities}"
								        RenderTransformOrigin="50%,50%">
									<i:Icon.Styles>
										<Style Selector="i|Icon">
											<Style.Animations>
												<Animation Duration="0:0:2.5" IterationCount="INFINITE">
													<KeyFrame Cue="0%">
														<Setter Property="RotateTransform.Angle" Value="0" />
													</KeyFrame>
													<KeyFrame Cue="100%">
														<Setter Property="RotateTransform.Angle" Value="360" />
													</KeyFrame>
												</Animation>
											</Style.Animations>
										</Style>
									</i:Icon.Styles>
								</i:Icon>
								<Border Background="OrangeRed" CornerRadius="6" MinWidth="12" Height="12"
								        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-6,0"
								        IsVisible="{Binding HasActiveActivities}" Padding="2,0" ClipToBounds="False">
									<TextBlock Text="{Binding ActivityBadgeCount}" FontSize="8" Foreground="White"
									           HorizontalAlignment="Center" VerticalAlignment="Center" />
								</Border>
							</Panel>
						</Button>
						<i:Icon Value="fa-solid fa-search" Margin="5,10,5,10" />
						<TextBox x:Name="SearchBox" Width="200" Watermark="Search..." Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="5,10,0,10" />
						<Button Command="{Binding ClearSearchCommand}" Background="Transparent" BorderThickness="0" Padding="4" Margin="2,10,10,10" VerticalAlignment="Center" Cursor="Hand" IsVisible="{Binding SearchText.Length}">
							<i:Icon Value="fa-solid fa-xmark" FontSize="14" />
						</Button>
					</StackPanel>
				</Border>
			</Grid>

			<!-- Status bar at bottom -->
			<controls:StatusBar DockPanel.Dock="Bottom" x:Name="MainStatusBar" DataContext="{Binding StatusBar}" Margin="4,0,4,0" />

			<!-- Sidebar + Content area with resizable splitter -->
			<Grid ColumnDefinitions="200,4,*" Margin="4">
				<controls:Sidebar Grid.Column="0" DataContext="{Binding}" />

				<GridSplitter Grid.Column="1" ResizeDirection="Columns" />

				<Grid Grid.Column="2" ColumnDefinitions="*,Auto">
					<Border Grid.Column="0" CornerRadius="8" ClipToBounds="True">
						<DockPanel>
							<controls:RadioFilterPanel x:Name="RadioFilterPanel"
								DockPanel.Dock="Bottom"
								DataContext="{Binding}"
								IsVisible="False" />

							<!-- CD audio action bar: same Bottom-docked convention as RadioFilterPanel.
							     Shown only when the active sidebar entry is an Audio CD. -->
							<Border DockPanel.Dock="Bottom"
									IsVisible="{Binding IsCdViewActive}"
									Padding="8,6">
								<StackPanel Orientation="Horizontal" Spacing="8">
									<Button Command="{Binding RipCurrentCdCommand}" Padding="10,4" Cursor="Hand" ToolTip.Tip="Rip the disc to disk">
										<StackPanel Orientation="Horizontal" Spacing="6">
											<i:Icon Value="fa-solid fa-compact-disc" FontSize="13" />
											<TextBlock Text="Rip CD…" VerticalAlignment="Center" />
										</StackPanel>
									</Button>
								</StackPanel>
							</Border>

							<ContentControl DockPanel.Dock="Top"
								Content="{Binding SelectedDevice}"
								IsVisible="{Binding SelectedDevice, Converter={x:Static ObjectConverters.IsNotNull}}">
								<ContentControl.ContentTemplate>
									<DataTemplate>
										<controls:DeviceInfoBar />
									</DataTemplate>
								</ContentControl.ContentTemplate>
							</ContentControl>

							<Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" IsVisible="{Binding IsDrillDownActive}">
								<controls:BreadcrumbBar x:Name="BreadcrumbBar" Grid.Column="0" />
								<Button Grid.Column="1" Command="{Binding ToggleDrillDownCommand}" Background="Transparent" BorderThickness="0" Padding="4" HorizontalAlignment="Right" Cursor="Hand" ToolTip.Tip="Exit Browse">
									<i:Icon Value="fa-solid fa-xmark" FontSize="12" Opacity="0.5" />
								</Button>
							</Grid>

							<DataGrid x:Name="DrillDownGrid"
								DoubleTapped="DrillDownGrid_DoubleTapped"
								ItemsSource="{Binding DrillDownEntries}"
								GridLinesVisibility="All"
								IsReadOnly="True"
								AutoGenerateColumns="False"
								CanUserSortColumns="True"
								SelectionMode="Single"
								Background="{DynamicResource SystemAltHighColor}"
								IsVisible="False">
								<DataGrid.Styles>
									<Style Selector="DataGridRow">
										<Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
									</Style>
									<Style Selector="DataGridRow:nth-child(odd)">
										<Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
									</Style>
								</DataGrid.Styles>
								<DataGrid.Columns />
							</DataGrid>

							<!-- Regular DataGrid for non-grouped views (Music, Favorites, Playlists, Ignored) -->
							<DataGrid x:Name="MainDataGrid"
								DoubleTapped="DataGrid_DoubleTapped"
								SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
								ItemsSource="{Binding FilteredItemsView}"
								GridLinesVisibility="All"
								IsReadOnly="True"
								AutoGenerateColumns="False"
								CanUserSortColumns="True"
								SelectionMode="Single"
								Background="{DynamicResource SystemAltHighColor}"
								HorizontalScrollBarVisibility="Auto"
								VerticalScrollBarVisibility="Auto">
								<DataGrid.Styles>
									<Style Selector="DataGridRow">
										<Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
									</Style>
									<Style Selector="DataGridRow:nth-child(odd)">
										<Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
									</Style>
									<Style Selector="DataGridCell:focus /template/ Grid#FocusVisual">
										<Setter Property="IsVisible" Value="False" />
									</Style>
									<Style Selector="DataGridCell TextBlock">
										<Setter Property="VerticalAlignment" Value="Center" />
									</Style>
								</DataGrid.Styles>
								<DataGrid.Columns />
							</DataGrid>

							<!-- Empty-state overlay: centered message when a search filter is active but
							     yields no matches. Drawn as a DockPanel fill child on top of the grids. -->
							<TextBlock Text="{Binding NoSearchResultsMessage}"
							           IsVisible="{Binding ShowNoSearchResults}"
							           HorizontalAlignment="Center"
							           VerticalAlignment="Center"
							           FontSize="16"
							           Opacity="0.6"
							           IsHitTestVisible="False" />

							<!-- Podcasts panel: replaces the data grids entirely when the
							     Podcasts sidebar item is active. Has its own internal store /
							     subscriptions / feed-detail navigation. -->
							<controls:PodcastsPanel x:Name="PodcastsPanel" DataContext="{Binding Podcasts}" IsVisible="False" />

							<!-- Separate DataGrid for grouped views (Radio) — never shares column state with MainDataGrid -->
							<DataGrid x:Name="GroupedDataGrid"
								DoubleTapped="DataGrid_DoubleTapped"
								SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
								ItemsSource="{Binding FilteredItemsView}"
								GridLinesVisibility="All"
								IsReadOnly="True"
								AutoGenerateColumns="False"
								CanUserSortColumns="True"
								SelectionMode="Single"
								Background="{DynamicResource SystemAltHighColor}"
								HorizontalScrollBarVisibility="Auto"
								VerticalScrollBarVisibility="Auto"
								IsVisible="False">
								<DataGrid.Styles>
									<Style Selector="DataGridRow">
										<Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
									</Style>
									<Style Selector="DataGridRow:nth-child(odd)">
										<Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
									</Style>
									<Style Selector="DataGridCell:focus /template/ Grid#FocusVisual">
										<Setter Property="IsVisible" Value="False" />
									</Style>
									<Style Selector="DataGridCell TextBlock">
										<Setter Property="VerticalAlignment" Value="Center" />
									</Style>
								</DataGrid.Styles>
								<DataGrid.Columns />
							</DataGrid>
						</DockPanel>
					</Border>

					<controls:QueuePanel Grid.Column="1" Width="250" Margin="4,0,0,0" DataContext="{Binding}" IsVisible="{Binding IsQueueVisible}" />
					<controls:ActivityPanel Grid.Column="1" Width="280" Margin="4,0,0,0" DataContext="{Binding}" IsVisible="{Binding IsActivityPanelVisible}" />
				</Grid>
			</Grid>
		</DockPanel>
		</Panel>
	</DockPanel>
</Window>
