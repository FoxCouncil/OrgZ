<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:Class="OrgZ.Views.SyncSettingsDialog"
		x:CompileBindings="False"
		Title="Sync Settings"
		Width="440" MinWidth="380" MaxWidth="640"
		MinHeight="240" MaxHeight="720"
		SizeToContent="Height"
		CanResize="True"
		WindowStartupLocation="CenterOwner"
		Classes="orgzDialog">
	<DockPanel Margin="16" LastChildFill="True">
		<TextBlock DockPanel.Dock="Top" x:Name="HeaderText" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" />

		<StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,14,0,0">
			<Button x:Name="SyncButton" Content="Save &amp; Sync" Width="120" Click="SyncButton_Click" />
			<Button x:Name="CancelButton" Content="Cancel" Width="80" Click="CancelButton_Click" />
		</StackPanel>

		<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
			<StackPanel Spacing="10">
				<CheckBox x:Name="AutomaticCheck" Content="Sync automatically (remove items no longer selected)" />
				<Separator Margin="0,0,0,2" />
				<CheckBox x:Name="PodcastsCheck" Content="Podcasts" />
				<CheckBox x:Name="AudiobooksCheck" Content="Audiobooks" />
				<CheckBox x:Name="FavoritesCheck" Content="Favorites" />

				<TextBlock x:Name="PlaylistsHeader" Text="Playlists" FontWeight="SemiBold" Margin="0,6,0,0" />
				<StackPanel x:Name="PlaylistList" Spacing="6" Margin="4,0,0,0" />
				<TextBlock x:Name="NoPlaylistsText" Text="No playlists in your library yet."
				           FontSize="12" Opacity="0.6" Margin="4,0,0,0" IsVisible="False" />
			</StackPanel>
		</ScrollViewer>
	</DockPanel>
</Window>
