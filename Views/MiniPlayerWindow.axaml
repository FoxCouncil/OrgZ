<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:controls="using:OrgZ.Controls"
        x:Class="OrgZ.Views.MiniPlayerWindow"
        x:CompileBindings="False"
        Title="OrgZ Mini-Player"
        Width="480" Height="82"
        MinWidth="480" MinHeight="82" MaxHeight="82"
        CanResize="True"
        Topmost="True"
        ShowInTaskbar="True"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>

        <!-- Consolas across all text so the mini-player matches the main window's
             LCD typography (size and weight differ per element; only the family
             is unified). Mirrors the equivalent style in MainWindow.axaml. -->
        <Style Selector="ContentPresenter, TextBlock, TextBox">
            <Setter Property="TextElement.FontFamily" Value="Consolas" />
        </Style>

        <!-- Duplicate of MainWindow's slider style so the mini-player's seek and
             volume sliders match the full player exactly.  Keep in sync with
             MainWindow.axaml by hand - NOT merged into a shared resource because
             the main-window look is the canonical design and shouldn't shift if
             someone tweaks the mini-player later. -->
        <Style Selector="Slider:horizontal">
            <Setter Property="MinHeight" Value="14" />
            <Setter Property="Margin" Value="0,-2,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource OrgZLcdProgressBrush}" />
            <Setter Property="Background" Value="{StaticResource OrgZLcdRimBrush}" />
            <Style Selector="^ Track">
                <Setter Property="Height" Value="14" />
                <Setter Property="Margin" Value="0" />
                <Style Selector="^ Thumb">
                    <Setter Property="Width" Value="14" />
                    <Setter Property="Height" Value="14" />
                    <Setter Property="CornerRadius" Value="0" />
                    <Setter Property="Background" Value="{StaticResource OrgZLcdProgressBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource OrgZLcdTextBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </Style>
        </Style>

        <!-- Transport buttons: same colors as MainWindow's transport cluster -
             SystemChromeGrayColor background with default Fluent foreground so
             hover / press states come from the FluentTheme defaults identically
             to the main player.  CornerRadius is set per-button in markup to
             get the round pill shape. -->
        <Style Selector="Button.xport">
            <Setter Property="Background" Value="{DynamicResource SystemChromeGrayColor}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Play button: visible ring outline that doesn't shift on hover /
             press - the icon glyph swaps between play / pause, but the button
             chrome itself holds still.  No pressed "dent", no hover tint. -->
        <Style Selector="Button.xportPlay">
            <Setter Property="Background" Value="{DynamicResource SystemChromeGrayColor}" />
            <Setter Property="BorderBrush" Value="#5A5A5A" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.xportPlay:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemChromeGrayColor}" />
            <Setter Property="BorderBrush" Value="#5A5A5A" />
        </Style>
        <Style Selector="Button.xportPlay:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemChromeGrayColor}" />
            <Setter Property="BorderBrush" Value="#5A5A5A" />
        </Style>

        <Style Selector="Button.winChrome">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#7B7B7B" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource OrgZMetalTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CornerRadius" Value="1" />
        </Style>
        <Style Selector="Button.winChrome:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#D8D8D8" />
        </Style>
    </Window.Styles>

    <Border CornerRadius="6" BorderThickness="1" BorderBrush="{StaticResource OrgZMetalRimBrush}"
            Background="{StaticResource OrgZMetalBrush}" ClipToBounds="True"
            PointerPressed="Chassis_PointerPressed">

        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Play / Pause" Command="{Binding ButtonPlayPause}" />
                <MenuItem Header="Previous Track" Command="{Binding ButtonPreviousTrack}" />
                <MenuItem Header="Next Track" Command="{Binding ButtonNextTrack}" />
                <Separator />
                <MenuItem Header="Switch LCD View" Command="{Binding CycleLcdPageCommand}" />
                <MenuItem Header="Now Playing Full-Screen…" Click="MenuFullScreen_Click" />
                <Separator />
                <MenuItem Header="Switch to Full Player" Click="MenuExpand_Click" />
                <MenuItem Header="Always on Top" x:Name="MenuAlwaysOnTop" Click="MenuAlwaysOnTop_Click" />
                <Separator />
                <MenuItem Header="Close Mini-Player" Click="MenuClose_Click" />
            </ContextMenu>
        </Border.ContextMenu>

        <Grid ColumnDefinitions="44,Auto,*,Auto" VerticalAlignment="Stretch">

            <!-- ===== Left chrome: platform-specific ===== -->

            <!-- macOS traffic lights -->
            <StackPanel x:Name="MacChrome" Grid.Column="0" Orientation="Vertical" Spacing="6"
                        HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="False">
                <Ellipse Width="12" Height="12" Cursor="Hand" Stroke="#9C2727" StrokeThickness="1"
                         PointerPressed="MacClose_PointerPressed" ToolTip.Tip="Close">
                    <Ellipse.Fill>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Offset="0" Color="#FF7B6C" />
                            <GradientStop Offset="1" Color="#D6423A" />
                        </LinearGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Width="12" Height="12" Cursor="Hand" Stroke="#A26A10" StrokeThickness="1"
                         PointerPressed="MacMinimize_PointerPressed" ToolTip.Tip="Minimize">
                    <Ellipse.Fill>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Offset="0" Color="#FFD17A" />
                            <GradientStop Offset="1" Color="#E2A522" />
                        </LinearGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Width="12" Height="12" Cursor="Hand" Stroke="#1F8A26" StrokeThickness="1"
                         PointerPressed="MacExpand_PointerPressed" ToolTip.Tip="Switch to full player">
                    <Ellipse.Fill>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Offset="0" Color="#72E580" />
                            <GradientStop Offset="1" Color="#32B247" />
                        </LinearGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </StackPanel>

            <!-- Windows / Linux chrome: square close / expand / minimize -->
            <StackPanel x:Name="WinChrome" Grid.Column="0" Orientation="Vertical" Spacing="4"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Classes="winChrome" Width="20" Height="16" Click="Close_Click" ToolTip.Tip="Close">
                    <i:Icon Value="fa-solid fa-xmark" FontSize="10" />
                </Button>
                <Button Classes="winChrome" Width="20" Height="16" Click="Expand_Click" ToolTip.Tip="Switch to full player">
                    <i:Icon Value="fa-solid fa-up-right-and-down-left-from-center" FontSize="8" />
                </Button>
                <Button Classes="winChrome" Width="20" Height="14" Click="Minimize_Click" ToolTip.Tip="Minimize">
                    <i:Icon Value="fa-solid fa-window-minimize" FontSize="8" />
                </Button>
            </StackPanel>

            <!-- ===== Transport cluster ===== -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,2,8,2" Spacing="0">

                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Button Classes="xport" Width="32" Height="32" CornerRadius="16"
                            IsEnabled="{Binding IsBackTrackButtonEnabled}"
                            i:Attached.Icon="fa-solid fa-backward-step" FontSize="14"
                            Command="{Binding ButtonPreviousTrack}" ToolTip.Tip="Previous" />
                    <Button Classes="xportPlay" Width="40" Height="40" CornerRadius="20"
                            IsEnabled="{Binding IsButtonPlayPauseEnabled}"
                            i:Attached.Icon="{Binding ButtonPlayPauseIcon}" FontSize="18"
                            Padding="{Binding ButtonPlayPausePadding}"
                            Command="{Binding ButtonPlayPause}" ToolTip.Tip="Play / Pause" />
                    <Button Classes="xport" Width="32" Height="32" CornerRadius="16"
                            IsEnabled="{Binding IsNextTrackButtonEnabled}"
                            i:Attached.Icon="fa-solid fa-forward-step" FontSize="14"
                            Command="{Binding ButtonNextTrack}" ToolTip.Tip="Next" />
                </StackPanel>

                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,-6,0,0">
                    <Button Grid.Column="0" Command="{Binding MuteVolumeCommand}" Background="Transparent" BorderThickness="0"
                            Padding="1" Cursor="Hand" VerticalAlignment="Center" ToolTip.Tip="Mute">
                        <i:Icon Value="fa-solid fa-volume-low" FontSize="11" Foreground="{StaticResource OrgZMetalTextBrush}" />
                    </Button>
                    <Slider Grid.Column="1" Minimum="0" Maximum="100"
                            Value="{Binding CurrentVolume, Mode=TwoWay}"
                            VerticalAlignment="Center" Margin="2,0" Height="18" Padding="0,-9,0,0" />
                    <Button Grid.Column="2" Command="{Binding MaxVolumeCommand}" Background="Transparent" BorderThickness="0"
                            Padding="1" Cursor="Hand" VerticalAlignment="Center" ToolTip.Tip="Max volume">
                        <i:Icon Value="fa-solid fa-volume-high" FontSize="11" Foreground="{StaticResource OrgZMetalTextBrush}" />
                    </Button>
                </Grid>
            </StackPanel>

            <!-- ===== LCD display =====
                 Shared with the main window via the LcdDisplay UserControl. The .mini
                 class shrinks the fonts + track-line heights so the same chrome fits
                 in the 82px-tall mini-player chassis. Page cycling lives on the
                 chevron button inside the LCD; double-click on the LCD body
                 still goes full-screen. -->
            <controls:LcdDisplay Grid.Column="2" Classes="mini"
                                 Margin="6,10,10,10" Cursor="Hand"
                                 PointerPressed="Lcd_PointerPressed" />

            <!-- ===== Audio output picker (speaker icon) ===== -->
            <Button Grid.Column="3" x:Name="AudioOutputButton" Click="AudioOutputButton_Click"
                    Background="Transparent" BorderThickness="0" Padding="6,0" Margin="2,0,6,0"
                    VerticalAlignment="Center" Cursor="Hand"
                    ToolTip.Tip="Audio output devices">
                <i:Icon Value="fa-solid fa-volume-high" FontSize="16"
                        Foreground="{StaticResource OrgZMetalTextBrush}" />
                <Button.Flyout>
                    <Flyout Placement="BottomEdgeAlignedRight">
                        <DockPanel MinWidth="320" MaxWidth="420" LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="Output Devices" FontWeight="Bold" FontSize="12"
                                       Margin="6,4,6,6" Foreground="{StaticResource OrgZTextForegroundBrush}" />
                            <TextBlock DockPanel.Dock="Top" x:Name="AudioOutputFlyoutHint"
                                       Text="" Opacity="0.6" FontSize="10" Margin="6,0,6,6"
                                       Foreground="{StaticResource OrgZMutedTextBrush}" />
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="6,6,6,6" Spacing="6">
                                <Button Content="Refresh" Click="AudioOutputRefresh_Click" FontSize="11" Padding="8,4" />
                                <Button Content="Open Settings…" Click="AudioOutputOpenSettings_Click" FontSize="11" Padding="8,4" />
                            </StackPanel>
                            <ScrollViewer MaxHeight="300" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="AudioOutputDeviceList" Spacing="4" Margin="6,0,6,0" />
                            </ScrollViewer>
                        </DockPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>

            <!-- ===== Edge resize grips =====
                 SystemDecorations=None means the window has no native chrome to
                 grab for resize. These transparent 6px overlays span all columns
                 and float at the left / right edges; PointerPressed kicks off a
                 native BeginResizeDrag so the user can pull the mini-player
                 wider or narrower like a normal resizable window. -->
            <Border Grid.Column="0" Grid.ColumnSpan="4" HorizontalAlignment="Left"
                    Width="6" Background="Transparent" Cursor="SizeWestEast"
                    PointerPressed="LeftEdgeResize_PointerPressed" />
            <Border Grid.Column="0" Grid.ColumnSpan="4" HorizontalAlignment="Right"
                    Width="6" Background="Transparent" Cursor="SizeWestEast"
                    PointerPressed="RightEdgeResize_PointerPressed" />

        </Grid>
    </Border>
</Window>
