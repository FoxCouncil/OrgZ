<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        x:Class="OrgZ.Views.NowPlayingFullScreenWindow"
        x:CompileBindings="False"
        Title="Now Playing"
        WindowStartupLocation="CenterScreen"
        WindowState="FullScreen"
        SystemDecorations="None"
        KeyDown="Window_KeyDown">

    <Panel Background="#000000">

        <!-- Background: blurred, amplified album art -->
        <Image Source="{Binding CurrentAlbumArt}" Stretch="UniformToFill" Opacity="0.35">
            <Image.Effect>
                <BlurEffect Radius="48" />
            </Image.Effect>
        </Image>

        <Grid RowDefinitions="*,Auto">

            <!-- Centerpiece -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                <Border Width="480" Height="480" CornerRadius="12" ClipToBounds="True"
                        Background="#222" Cursor="Hand" PointerPressed="Window_PointerPressed">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" OffsetX="0" OffsetY="10" Color="#000000" Opacity="0.8" />
                    </Border.Effect>
                    <Panel>
                        <Image Source="{Binding CurrentAlbumArt}" Stretch="UniformToFill"
                               IsVisible="{Binding CurrentAlbumArt, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <i:Icon Value="fa-solid fa-music" FontSize="128"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Foreground="White" Opacity="0.4"
                                IsVisible="{Binding CurrentAlbumArt, Converter={x:Static ObjectConverters.IsNull}}" />
                    </Panel>
                </Border>

                <StackPanel HorizontalAlignment="Center" Spacing="6">
                    <TextBlock Text="{Binding CurrentTrackLine1}" FontSize="32" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                               MaxWidth="900" TextAlignment="Center" />
                    <TextBlock Text="{Binding CurrentTrackLine2}" FontSize="20" Opacity="0.8"
                               Foreground="White" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                               MaxWidth="900" TextAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <!-- Transport + seek bar (auto-hides after 3s of pointer idle) -->
            <StackPanel x:Name="TransportLayer" Grid.Row="1" Margin="64,0,64,56" Spacing="16">

                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding CurrentTrackTime}" FontSize="14" Foreground="White" VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Margin="12,0" Minimum="0" Maximum="{Binding CurrentTrackDurationNumber}"
                            Value="{Binding CurrentTrackTimeNumber, Mode=TwoWay}"
                            IsEnabled="{Binding IsSeekEnabled}" IsVisible="{Binding IsSeekEnabled}"
                            VerticalAlignment="Center" Height="14" />
                    <TextBlock Grid.Column="2" Text="{Binding CurrentTrackDuration}" FontSize="14" Foreground="White" VerticalAlignment="Center" />
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                    <Button IsEnabled="{Binding IsBackTrackButtonEnabled}" Width="54" Height="54" FontSize="22" CornerRadius="27"
                            Background="#222" BorderThickness="0"
                            i:Attached.Icon="fa-solid fa-backward-step" Command="{Binding ButtonPreviousTrack}" />
                    <Button IsEnabled="{Binding IsButtonPlayPauseEnabled}" Width="72" Height="72" FontSize="32" CornerRadius="36"
                            Background="White" Foreground="Black" BorderThickness="0"
                            i:Attached.Icon="{Binding ButtonPlayPauseIcon}" Command="{Binding ButtonPlayPause}"
                            Padding="{Binding ButtonPlayPausePadding}" />
                    <Button IsEnabled="{Binding IsNextTrackButtonEnabled}" Width="54" Height="54" FontSize="22" CornerRadius="27"
                            Background="#222" BorderThickness="0"
                            i:Attached.Icon="fa-solid fa-forward-step" Command="{Binding ButtonNextTrack}" />
                </StackPanel>

                <TextBlock Text="Press Esc or double-click to exit full-screen" FontSize="11" Opacity="0.5"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>

            <!-- Close button top-right -->
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16" Width="32" Height="32"
                    Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand"
                    i:Attached.Icon="fa-solid fa-xmark" FontSize="18" Click="Close_Click"
                    ToolTip.Tip="Close (Esc)" />
        </Grid>

    </Panel>
</Window>
