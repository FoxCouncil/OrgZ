<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:Class="OrgZ.Views.ConfirmDialog"
		x:CompileBindings="False"
		Title="Confirm"
		Width="420" MinWidth="380" MaxWidth="640"
		SizeToContent="Height"
		CanResize="True"
		WindowStartupLocation="CenterOwner"
		Classes="orgzDialog">
	<StackPanel Margin="16" Spacing="12">
		<TextBlock x:Name="MessageText" Text="" TextWrapping="Wrap" MinHeight="48" />
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
			<Button x:Name="ConfirmButton" Content="OK" Width="90" Click="ConfirmButton_Click" />
			<Button x:Name="CancelButton" Content="Cancel" Width="70" Click="CancelButton_Click" />
		</StackPanel>
	</StackPanel>
</Window>
