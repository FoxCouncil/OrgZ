<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             x:Class="OrgZ.Controls.ActivityPanel"
             x:CompileBindings="False">
	<Border Background="{DynamicResource SystemAltHighColor}" BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}" BorderThickness="1,0,0,0">
		<DockPanel>
			<Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="8,8,8,4">
				<TextBlock Text="Activity" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
				<Button Grid.Column="1" Command="{Binding ClearCompletedActivitiesCommand}" Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand" ToolTip.Tip="Clear Completed">
					<i:Icon Value="fa-solid fa-trash" FontSize="12" Opacity="0.5" />
				</Button>
			</Grid>

			<ListBox ItemsSource="{Binding Activities}" SelectionMode="Single" Background="Transparent" Margin="0,4,0,0">
				<ListBox.ItemTemplate>
					<DataTemplate>
						<StackPanel Margin="4,4">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<i:Icon Value="{Binding StatusIcon}" FontSize="12" Foreground="{Binding StatusColor}" VerticalAlignment="Center" />
								<TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" FontSize="12" FontWeight="SemiBold" />
							</StackPanel>
							<TextBlock Text="{Binding Detail}" TextTrimming="CharacterEllipsis" FontSize="10" Opacity="0.6" Margin="18,0,0,0"
							           IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
							<ProgressBar Minimum="0" Maximum="1" Value="{Binding Progress}" Height="3" Margin="18,4,0,0"
							             IsVisible="{Binding Progress, Converter={x:Static ObjectConverters.IsNotNull}}"
							             Foreground="#4A9EFF" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
							<TextBlock Text="{Binding Error}" TextWrapping="Wrap" FontSize="10" Foreground="OrangeRed" Margin="18,2,0,0"
							           IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
						</StackPanel>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>
		</DockPanel>
	</Border>
</UserControl>
