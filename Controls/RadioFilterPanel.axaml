<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="40"
             x:Class="OrgZ.Controls.RadioFilterPanel"
             x:CompileBindings="False">
    <Border Padding="8,4">
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Country:" VerticalAlignment="Center" Opacity="0.6" />
            <ComboBox ItemsSource="{Binding Countries}"
                      SelectedItem="{Binding SelectedCountry, Mode=TwoWay}"
                      Width="160"
                      VerticalAlignment="Center" />

            <TextBlock Text="Genre:" VerticalAlignment="Center" Opacity="0.6" />
            <ComboBox ItemsSource="{Binding Genres}"
                      SelectedItem="{Binding SelectedGenre, Mode=TwoWay}"
                      Width="160"
                      VerticalAlignment="Center" />

            <Button x:Name="AddStationButton"
                    Click="AddStation_Click"
                    ToolTip.Tip="Add User Station"
                    VerticalAlignment="Center">
                <i:Icon Value="fa-solid fa-plus" FontSize="14" />
            </Button>
            <Button Command="{Binding FetchPopularStationsCommand}"
                    ToolTip.Tip="Fetch Popular Stations"
                    VerticalAlignment="Center">
                <i:Icon Value="fa-solid fa-arrows-rotate" FontSize="14" />
            </Button>
            <Button x:Name="SyncButton"
                    Click="SyncButton_Click"
                    ToolTip.Tip="Sync All Stations (~95k)"
                    VerticalAlignment="Center"
                    IsEnabled="{Binding !IsSyncing}">
                <i:Icon Value="fa-solid fa-cloud-arrow-down" FontSize="14" />
            </Button>
        </StackPanel>
    </Border>
</UserControl>
