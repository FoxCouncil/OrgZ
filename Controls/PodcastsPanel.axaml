<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:vm="using:OrgZ.ViewModels"
             xmlns:controls="using:OrgZ.Controls"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             x:Class="OrgZ.Controls.PodcastsPanel"
             Background="{StaticResource OrgZPodcastSurfaceBrush}"
             x:CompileBindings="False">
	<Design.DataContext>
		<vm:PodcastsViewModel />
	</Design.DataContext>

	<!-- ==================== Layered content ====================
	     A Top-docked nav header surfaces a < Back button when the panel
	     isn't on the Store view. FeedDetail owns its own scrolling (the
	     DataGrid scrolls internally), so it sits as a sibling of the
	     ScrollViewer that hosts Store + Subscriptions. -->
	<DockPanel LastChildFill="True">
		<Border DockPanel.Dock="Top"
		        Background="{StaticResource OrgZSurfaceDarkBrush}"
		        BorderBrush="{StaticResource OrgZBorderColorBrush}"
		        BorderThickness="0,0,0,1"
		        IsVisible="{Binding !IsStore}"
		        Height="40">
			<Button Command="{Binding GoBackCommand}"
			        HorizontalAlignment="Left"
			        VerticalAlignment="Center"
			        Margin="10,0"
			        Padding="12,5"
			        Cursor="Hand">
				<StackPanel Orientation="Horizontal" Spacing="6">
					<i:Icon Value="fa-solid fa-chevron-left" FontSize="12"
					        VerticalAlignment="Center" />
					<!-- LineHeight 10 collapses the text's line box just enough
					     to align its visual baseline with the FA glyph. -->
					<TextBlock Text="Back" FontSize="12" LineHeight="10"
					           VerticalAlignment="Center" />
				</StackPanel>
			</Button>
		</Border>

		<Grid>
			<controls:PodcastsFeedDetailView IsVisible="{Binding IsFeedDetail}" />

			<ScrollViewer HorizontalScrollBarVisibility="Disabled"
			              VerticalScrollBarVisibility="Auto"
			              IsVisible="{Binding !IsFeedDetail}">
				<Grid>
					<controls:PodcastsStoreView IsVisible="{Binding IsStore}" />
					<controls:PodcastsFeedListView IsVisible="{Binding IsFeedList}" />
					<controls:PodcastsSubscriptionsView IsVisible="{Binding IsSubscriptions}" />
				</Grid>
			</ScrollViewer>
		</Grid>
	</DockPanel>
</UserControl>
