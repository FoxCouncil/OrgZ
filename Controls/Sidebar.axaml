<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:vm="using:OrgZ.ViewModels"
             xmlns:models="using:OrgZ.Models"
             mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="450"
             x:Class="OrgZ.Controls.Sidebar"
             x:CompileBindings="False">

    <Border Width="200" CornerRadius="8" ClipToBounds="True">
        <Border.Background>
            <SolidColorBrush Color="#1A1A1A" />
        </Border.Background>

        <DockPanel>
            <!-- LIBRARY header -->
            <TextBlock DockPanel.Dock="Top"
                       Text="LIBRARY"
                       FontFamily="Consolas"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="{DynamicResource SystemControlDisabledBaseMediumLowBrush}"
                       Margin="16,12,0,4" />

            <!-- Library items -->
            <ListBox DockPanel.Dock="Top"
                     x:Name="LibraryListBox"
                     ItemsSource="{Binding LibraryItems}"
                     SelectedItem="{Binding SelectedSidebarItem, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0"
                     Margin="0,0,0,4">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="16,6" />
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="FontFamily" Value="Consolas" />
                    </Style>
                    <Style Selector="ListBoxItem:disabled">
                        <Setter Property="Opacity" Value="0.4" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:SidebarItem">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <i:Icon Value="{Binding Icon}" FontSize="14" Width="18" />
                            <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerTheme>
                    <ControlTheme TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                    </ControlTheme>
                </ListBox.ItemContainerTheme>
            </ListBox>

            <!-- Separator -->
            <Separator DockPanel.Dock="Top"
                       Background="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"
                       Height="1"
                       Margin="12,4" />

            <!-- PLAYLISTS header -->
            <TextBlock DockPanel.Dock="Top"
                       Text="PLAYLISTS"
                       FontFamily="Consolas"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="{DynamicResource SystemControlDisabledBaseMediumLowBrush}"
                       Margin="16,8,0,4" />

            <!-- Playlist items -->
            <ListBox DockPanel.Dock="Top"
                     x:Name="PlaylistListBox"
                     ItemsSource="{Binding PlaylistItems}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="16,6" />
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="FontFamily" Value="Consolas" />
                    </Style>
                    <Style Selector="ListBoxItem:disabled">
                        <Setter Property="Opacity" Value="0.4" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:SidebarItem">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <i:Icon Value="{Binding Icon}" FontSize="14" Width="18" />
                            <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerTheme>
                    <ControlTheme TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                    </ControlTheme>
                </ListBox.ItemContainerTheme>
            </ListBox>

            <!-- Fill remaining space -->
            <Border />
        </DockPanel>
    </Border>
</UserControl>
