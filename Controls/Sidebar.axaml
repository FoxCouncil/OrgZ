<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:vm="using:OrgZ.ViewModels"
             xmlns:models="using:OrgZ.Models"
             mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="450"
             x:Class="OrgZ.Controls.Sidebar"
             x:CompileBindings="False">

    <UserControl.Styles>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="FontFamily" Value="{StaticResource OrgZMonoFont}" />
        </Style>
        <Style Selector="ListBoxItem:disabled">
            <Setter Property="Opacity" Value="0.4" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <DataTemplate x:Key="SidebarItemTemplate" x:DataType="models:SidebarItem">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <!-- Left indent for sub-rows (e.g. Subscriptions under Podcasts). The 10px
                     StackPanel spacing is added on top, landing the icon ~16px in. -->
                <Border Width="6" IsVisible="{Binding IsSubItem}" />
                <Border Width="18" Height="18" ClipToBounds="True" VerticalAlignment="Center">
                    <Panel>
                        <Image Source="{Binding IconBitmap}"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsVisible="{Binding HasIconBitmap}" />
                        <i:Icon Value="{Binding Icon}" FontSize="14"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                IsVisible="{Binding !HasIconBitmap}" />
                    </Panel>
                </Border>
                <TextBlock Text="{Binding Name}" FontSize="16" VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>
        <TreeDataTemplate x:Key="DeviceTreeTemplate" x:DataType="models:SidebarItem" ItemsSource="{Binding Children}">
            <!-- ChevronContainer is collapsed out of layout by the container
                 theme above; we then push the row by the ListBoxItem's
                 16px-left padding so the icon sits in the same column as the
                 LIBRARY rows. -->
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="16,0,0,0">
                <Border Width="18" Height="18" ClipToBounds="True" VerticalAlignment="Center">
                    <Panel>
                        <Image Source="{Binding IconBitmap}"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsVisible="{Binding HasIconBitmap}" />
                        <i:Icon Value="{Binding Icon}" FontSize="14"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                IsVisible="{Binding !HasIconBitmap}" />
                    </Panel>
                </Border>
                <TextBlock Text="{Binding Name}" FontSize="16" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </TreeDataTemplate>
        <ControlTheme x:Key="SidebarItemContainerTheme" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
        </ControlTheme>
        <ControlTheme x:Key="DeviceTreeItemTheme" TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
            <Setter Property="IsExpanded" Value="True" />
            <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
            <!-- Kill the entire chevron column. Hiding only the inner
                 ToggleButton leaves the container's 12,0,12,0 margin in
                 layout - that 24px reservation is what nudged the device
                 icon out of alignment with the LIBRARY ListBox above. -->
            <Style Selector="^ /template/ Panel#PART_ExpandCollapseChevronContainer">
                <Setter Property="IsVisible" Value="False" />
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <Border MinWidth="140" MaxWidth="350" CornerRadius="8" ClipToBounds="True"
            Background="{StaticResource OrgZSurfaceDarkBrush}">

        <DockPanel>
            <!-- LIBRARY header -->
            <TextBlock DockPanel.Dock="Top"
                       Text="LIBRARY"
                       FontFamily="{StaticResource OrgZMonoFont}"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="{DynamicResource SystemControlDisabledBaseMediumLowBrush}"
                       Margin="16,12,0,4" />

            <!-- Library items -->
            <ListBox DockPanel.Dock="Top"
                     x:Name="LibraryListBox"
                     ItemsSource="{Binding LibraryItems}"
                     SelectedItem="{Binding SelectedSidebarItem, Mode=OneWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0"
                     Margin="0,0,0,4"
                     ItemTemplate="{StaticResource SidebarItemTemplate}"
                     ItemContainerTheme="{StaticResource SidebarItemContainerTheme}"
                     SelectionChanged="LibraryListBox_SelectionChanged"
                     ContextRequested="LibraryListBox_ContextRequested" />

            <!-- Separator -->
            <Separator DockPanel.Dock="Top"
                       Background="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"
                       Height="1"
                       Margin="12,4" />

            <!-- DEVICES header -->
            <TextBlock DockPanel.Dock="Top"
                       Text="DEVICES"
                       FontFamily="{StaticResource OrgZMonoFont}"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="{DynamicResource SystemControlDisabledBaseMediumLowBrush}"
                       Margin="16,8,0,4" />

            <!-- Device tree: each connected device is a parent with Music/Playlists
                 as children. Auto-expanded by the container theme so the nested items
                 are always visible - the chevron still toggles if the user wants. -->
            <TreeView DockPanel.Dock="Top"
                      x:Name="DeviceTreeView"
                      ItemsSource="{Binding DeviceItems}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      Margin="0,0,0,4"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ItemTemplate="{StaticResource DeviceTreeTemplate}"
                      ItemContainerTheme="{StaticResource DeviceTreeItemTheme}"
                      SelectionChanged="DeviceTreeView_SelectionChanged" />

            <!-- "No devices" placeholder, shown only when DeviceItems is empty -->
            <TextBlock DockPanel.Dock="Top"
                       Text="No devices connected"
                       FontFamily="{StaticResource OrgZMonoFont}"
                       FontSize="12"
                       FontStyle="Italic"
                       Foreground="{DynamicResource SystemControlDisabledBaseMediumLowBrush}"
                       Margin="34,2,0,4"
                       IsVisible="{Binding !DeviceItems.Count}" />

            <!-- Separator -->
            <Separator DockPanel.Dock="Top"
                       Background="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"
                       Height="1"
                       Margin="12,4" />

            <!-- PLAYLISTS header -->
            <TextBlock DockPanel.Dock="Top"
                       Text="PLAYLISTS"
                       FontFamily="{StaticResource OrgZMonoFont}"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="{DynamicResource SystemControlDisabledBaseMediumLowBrush}"
                       Margin="16,8,0,4" />

            <!-- Playlist items -->
            <ListBox DockPanel.Dock="Top"
                     x:Name="PlaylistListBox"
                     ItemsSource="{Binding PlaylistItems}"
                     SelectedItem="{Binding SelectedSidebarItem, Mode=OneWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0"
                     ItemTemplate="{StaticResource SidebarItemTemplate}"
                     ItemContainerTheme="{StaticResource SidebarItemContainerTheme}"
                     SelectionChanged="PlaylistListBox_SelectionChanged"
                     DragDrop.AllowDrop="True" />

            <!-- Fill remaining space -->
            <Border />
        </DockPanel>
    </Border>
</UserControl>
