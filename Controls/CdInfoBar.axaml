<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:controls="using:OrgZ.Controls"
             xmlns:models="using:OrgZ.Models"
             xmlns:vm="using:OrgZ.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="120"
             x:Class="OrgZ.Controls.CdInfoBar"
             x:DataType="models:CdInfo">

    <controls:MediaHeaderBar ArtSize="84">

        <!-- Cover art: the CD's front cover when available, otherwise a generic disc glyph. -->
        <controls:MediaHeaderBar.Art>
            <Panel>
                <Image Source="{Binding CoverArt}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="{Binding HasCoverArt}" />
                <i:Icon Value="fa-solid fa-compact-disc" FontSize="40"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        IsVisible="{Binding !HasCoverArt}" />
            </Panel>
        </controls:MediaHeaderBar.Art>

        <!-- Identity: album/artist headline + the disc details. -->
        <controls:MediaHeaderBar.Body>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding AlbumDisplay}"
                           FontSize="16" FontWeight="Bold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Row="1" Text="{Binding ArtistDisplay}"
                           FontSize="12" Opacity="0.8"
                           TextTrimming="CharacterEllipsis" />

                <!-- Detail row: a horizontal run of label/value pairs. -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Year:" Classes="label" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding YearDisplay}" Classes="value" />

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Genre:" Classes="label" />
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding GenreDisplay}" Classes="value" />

                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Tracks:" Classes="label" />
                    <TextBlock Grid.Row="0" Grid.Column="7" Text="{Binding TrackCountDisplay}" Classes="value" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Time:" Classes="label" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalTimeDisplay}" Classes="value" />

                    <TextBlock Grid.Row="1" Grid.Column="3" Text="DiscID:" Classes="label" />
                    <TextBlock Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="4"
                               Text="{Binding DiscIdDisplay}" Classes="value"
                               FontFamily="Cascadia Mono,Consolas,monospace"
                               ToolTip.Tip="{Binding ReleaseMbidDisplay}" />
                </Grid>
            </Grid>
        </controls:MediaHeaderBar.Body>

        <!-- Actions: Rip + Eject. -->
        <controls:MediaHeaderBar.Actions>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Padding="10,6" Cursor="Hand"
                        ToolTip.Tip="Rip the disc to disk"
                        Command="{Binding ((vm:MainWindowViewModel)DataContext).RipCurrentCdCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <i:Icon Value="fa-solid fa-compact-disc" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="Rip CD…" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Padding="10,6" Cursor="Hand"
                        ToolTip.Tip="Eject this disc"
                        Command="{Binding ((vm:MainWindowViewModel)DataContext).EjectCdCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <i:Icon Value="fa-solid fa-eject" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="Eject" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </controls:MediaHeaderBar.Actions>

    </controls:MediaHeaderBar>

</UserControl>
