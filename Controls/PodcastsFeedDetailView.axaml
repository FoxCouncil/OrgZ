<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:vm="using:OrgZ.ViewModels"
             xmlns:models="using:OrgZ.Models"
             xmlns:img="clr-namespace:OrgZ.Converters"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             x:Class="OrgZ.Controls.PodcastsFeedDetailView"
             Background="{StaticResource OrgZPodcastSurfaceBrush}"
             x:CompileBindings="False">
	<Design.DataContext>
		<vm:PodcastsViewModel />
	</Design.DataContext>
	<UserControl.Styles>
		<StyleInclude Source="avares://OrgZ/Controls/PodcastStyles.axaml" />
		<!-- Continuous spin for the in-progress download glyph — same motion as the CD rip
		     indicator. RotateTransform.Angle auto-applies a centered RotateTransform. -->
		<Style Selector="i|Icon.downloadSpin">
			<Style.Animations>
				<Animation Duration="0:0:0.9" IterationCount="INFINITE" Easing="LinearEasing">
					<KeyFrame Cue="0%">
						<Setter Property="RotateTransform.Angle" Value="0" />
					</KeyFrame>
					<KeyFrame Cue="100%">
						<Setter Property="RotateTransform.Angle" Value="360" />
					</KeyFrame>
				</Animation>
			</Style.Animations>
		</Style>
		<!-- Downloaded button: green check by default, swaps to a red trash can on hover
		     (clicking it confirms removing the download). No local IsVisible on the icons so
		     these hover styles win; the parent Panel gates the whole thing on IsDownloaded. -->
		<Style Selector="i|Icon.dlTrash">
			<Setter Property="IsVisible" Value="False" />
		</Style>
		<Style Selector="Button:pointerover i|Icon.dlCheck">
			<Setter Property="IsVisible" Value="False" />
		</Style>
		<Style Selector="Button:pointerover i|Icon.dlTrash">
			<Setter Property="IsVisible" Value="True" />
		</Style>
	</UserControl.Styles>

	<Grid RowDefinitions="Auto,*">
		<Border Grid.Row="0" Background="{StaticResource OrgZPodcastSurfaceBrush}" Padding="16">
			<Grid ColumnDefinitions="Auto,*,Auto">
				<Border Grid.Column="0" Classes="tileArt" Width="140" Height="140" Margin="0,0,16,0">
					<Image img:RemoteImage.Url="{Binding SelectedFeed.DisplayImage}" Stretch="UniformToFill" />
				</Border>
				<StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Top">
					<TextBlock Text="{Binding SelectedFeed.Title}" FontSize="22" FontWeight="Bold" TextWrapping="Wrap" />
					<TextBlock Text="{Binding SelectedFeed.Author}" FontSize="13" Opacity="0.7" />
					<SelectableTextBlock x:Name="FeedDescriptionBlock"
					                     FontSize="12" Opacity="0.85" TextWrapping="Wrap"
					                     MaxLines="4" TextTrimming="CharacterEllipsis"
					                     PointerPressed="FeedDescriptionBlock_PointerPressed"
					                     PointerMoved="FeedDescriptionBlock_PointerMoved" />
				</StackPanel>
				<StackPanel Grid.Column="2" VerticalAlignment="Top" Spacing="8">
					<Button Command="{Binding ToggleSubscribeCommand}" Padding="14,6" Cursor="Hand">
						<StackPanel Orientation="Horizontal" Spacing="6">
							<i:Icon Value="fa-solid fa-bookmark" FontSize="12" />
							<TextBlock Text="Subscribe" IsVisible="{Binding !SelectedFeedIsSubscribed}" />
							<TextBlock Text="Unsubscribe" IsVisible="{Binding SelectedFeedIsSubscribed}" />
						</StackPanel>
					</Button>

					<!-- Per-podcast rule overrides, shown once subscribed. "Use default" (index 0)
					     defers to the global Settings rules; anything else overrides them for
					     this show. Item order mirrors PodcastSettings' tag arrays. -->
					<StackPanel Width="220" Spacing="4" IsVisible="{Binding SelectedFeedIsSubscribed}">
						<TextBlock Text="New episodes" FontSize="11" Opacity="0.7" Margin="0,4,0,0" />
						<ComboBox HorizontalAlignment="Stretch"
						          SelectedIndex="{Binding SelectedFeedActionIndex, Mode=TwoWay}">
							<ComboBoxItem Content="Use default" />
							<ComboBoxItem Content="Download all" />
							<ComboBoxItem Content="Download recent" />
							<ComboBoxItem Content="Do nothing" />
						</ComboBox>

						<TextBlock Text="Keep" FontSize="11" Opacity="0.7" Margin="0,6,0,0" />
						<ComboBox HorizontalAlignment="Stretch"
						          SelectedIndex="{Binding SelectedFeedKeepIndex, Mode=TwoWay}">
							<ComboBoxItem Content="Use default" />
							<ComboBoxItem Content="All episodes" />
							<ComboBoxItem Content="All unplayed" />
							<ComboBoxItem Content="Most recent" />
							<ComboBoxItem Content="Most recent 2" />
							<ComboBoxItem Content="Most recent 5" />
							<ComboBoxItem Content="Most recent 10" />
						</ComboBox>
					</StackPanel>
				</StackPanel>
			</Grid>
		</Border>

		<DataGrid Grid.Row="1" x:Name="EpisodesGrid"
		          ItemsSource="{Binding SelectedFeedEpisodes}"
		          DoubleTapped="EpisodesGrid_DoubleTapped"
		          GridLinesVisibility="All"
		          IsReadOnly="True"
		          AutoGenerateColumns="False"
		          CanUserSortColumns="True"
		          SelectionMode="Single"
		          Background="{DynamicResource SystemAltHighColor}"
		          HorizontalScrollBarVisibility="Auto"
		          VerticalScrollBarVisibility="Auto">
			<DataGrid.ContextMenu>
				<ContextMenu>
					<MenuItem Header="Play" Click="ContextPlay_Click" />
					<MenuItem Header="Download" Click="ContextDownload_Click" />
					<Separator />
					<MenuItem Header="Get Info" Click="ContextGetInfo_Click" />
				</ContextMenu>
			</DataGrid.ContextMenu>
			<DataGrid.Styles>
				<Style Selector="DataGridRow">
					<Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
				</Style>
				<Style Selector="DataGridRow:nth-child(odd)">
					<Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
				</Style>
				<Style Selector="DataGridCell:focus /template/ Grid#FocusVisual">
					<Setter Property="IsVisible" Value="False" />
				</Style>
				<Style Selector="DataGridCell TextBlock">
					<Setter Property="VerticalAlignment" Value="Center" />
				</Style>
			</DataGrid.Styles>
			<DataGrid.Columns>
				<DataGridTextColumn Header="Episode" Binding="{Binding Title}" Width="*" />
				<DataGridTextColumn Header="Published" Binding="{Binding DatePublishedPretty}" Width="160" />
				<DataGridTextColumn Header="Duration" Binding="{Binding DurationLabel}" Width="100" />
				<DataGridTemplateColumn Header="" Width="48" CanUserSort="False" CanUserResize="False" CanUserReorder="False">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate DataType="vm:PodcastEpisodeRow">
							<!-- Single download button per row. Play is reachable via row
							     double-click and the context menu, so the dedicated play
							     button was duplicating affordances. Four overlaid icons
							     swap on DownloadState; tooltip is generic and the icon
							     carries the meaning. -->
							<Button Click="DownloadEpisode_Click" Tag="{Binding}"
							        HorizontalAlignment="Center" VerticalAlignment="Center"
							        Padding="6,3" Cursor="Hand"
							        ToolTip.Tip="Download (click to (re)fetch)">
								<Panel>
									<i:Icon Value="fa-solid fa-download" FontSize="11"
									        IsVisible="{Binding IsNotDownloaded}" />
									<i:Icon Value="fa-solid fa-spinner" FontSize="11" Classes="downloadSpin"
									        RenderTransformOrigin="50%,50%"
									        IsVisible="{Binding IsDownloading}" />
									<!-- Downloaded: green check, swaps to a red trash on hover; click confirms removal. -->
									<Panel IsVisible="{Binding IsDownloaded}">
										<i:Icon Value="fa-solid fa-check" FontSize="11" Classes="dlCheck"
										        Foreground="{StaticResource OrgZSuccessBrush}" />
										<i:Icon Value="fa-solid fa-trash" FontSize="11" Classes="dlTrash"
										        Foreground="#E53935" />
									</Panel>
									<i:Icon Value="fa-solid fa-triangle-exclamation" FontSize="11"
									        Foreground="{StaticResource OrgZWarningBrush}"
									        IsVisible="{Binding IsIncomplete}" />
								</Panel>
							</Button>
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>
			</DataGrid.Columns>
		</DataGrid>

		<!-- Overlay status messages on top of the DataGrid area. -->
		<TextBlock Grid.Row="1" Text="Loading episodes…"
		           IsVisible="{Binding IsLoadingFeed}"
		           HorizontalAlignment="Center" VerticalAlignment="Center"
		           Opacity="0.6" FontSize="14" IsHitTestVisible="False" />
		<TextBlock Grid.Row="1" Text="No episodes available for this podcast."
		           HorizontalAlignment="Center" VerticalAlignment="Center"
		           Opacity="0.6" FontSize="14" IsHitTestVisible="False">
			<TextBlock.IsVisible>
				<MultiBinding Converter="{x:Static BoolConverters.And}">
					<Binding Path="!IsLoadingFeed" />
					<Binding Path="SelectedFeedEpisodes.Count" Converter="{x:Static ObjectConverters.Equal}" ConverterParameter="0" />
				</MultiBinding>
			</TextBlock.IsVisible>
		</TextBlock>
	</Grid>
</UserControl>
