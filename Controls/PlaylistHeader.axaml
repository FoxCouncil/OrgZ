<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:controls="using:OrgZ.Controls"
             xmlns:models="using:OrgZ.Models"
             xmlns:vm="using:OrgZ.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="100"
             x:Class="OrgZ.Controls.PlaylistHeader"
             x:DataType="models:PlaylistHeaderInfo">

    <!-- ArtSize 84 matches the CD album-art tile so the headers line up. -->
    <controls:MediaHeaderBar ArtSize="84">

        <!-- One tile per song (first four): each cell layers the song's cover over a no-art
             placeholder square, so a song without art - or a cell past the song count - shows the
             placeholder. Falls back to a single music glyph only when NO tile has art. -->
        <controls:MediaHeaderBar.Art>
            <Panel>
                <i:Icon Value="fa-solid fa-music" FontSize="34"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Opacity="0.4"
                        IsVisible="{Binding !HasAnyCover}" />
                <Grid ColumnDefinitions="*,*" RowDefinitions="*,*"
                      IsVisible="{Binding HasAnyCover}">
                    <Panel Grid.Row="0" Grid.Column="0">
                        <Border Background="{StaticResource OrgZReadonlyBackgroundBrush}">
                            <i:Icon Value="fa-solid fa-music" FontSize="14" Opacity="0.3"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Image Source="{Binding Cover1}" Stretch="UniformToFill" />
                    </Panel>
                    <Panel Grid.Row="0" Grid.Column="1">
                        <Border Background="{StaticResource OrgZReadonlyBackgroundBrush}">
                            <i:Icon Value="fa-solid fa-music" FontSize="14" Opacity="0.3"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Image Source="{Binding Cover2}" Stretch="UniformToFill" />
                    </Panel>
                    <Panel Grid.Row="1" Grid.Column="0">
                        <Border Background="{StaticResource OrgZReadonlyBackgroundBrush}">
                            <i:Icon Value="fa-solid fa-music" FontSize="14" Opacity="0.3"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Image Source="{Binding Cover3}" Stretch="UniformToFill" />
                    </Panel>
                    <Panel Grid.Row="1" Grid.Column="1">
                        <Border Background="{StaticResource OrgZReadonlyBackgroundBrush}">
                            <i:Icon Value="fa-solid fa-music" FontSize="14" Opacity="0.3"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Image Source="{Binding Cover4}" Stretch="UniformToFill" />
                    </Panel>
                </Grid>
            </Panel>
        </controls:MediaHeaderBar.Art>

        <!-- Name + source + stats. -->
        <controls:MediaHeaderBar.Body>
            <StackPanel VerticalAlignment="Center" Spacing="3">
                <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold"
                           TextTrimming="CharacterEllipsis" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding SourceLabel}" FontSize="11" FontWeight="Bold" Opacity="0.55"
                               IsVisible="{Binding ShowSourceLabel}" />
                    <TextBlock Text="·" FontSize="11" Opacity="0.4"
                               IsVisible="{Binding ShowSourceLabel}" />
                    <TextBlock Text="{Binding Summary}" FontSize="11" Opacity="0.7"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </StackPanel>
        </controls:MediaHeaderBar.Body>

        <!-- Actions: Sync + Burn. -->
        <controls:MediaHeaderBar.Actions>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Padding="12,6" Cursor="Hand"
                        ToolTip.Tip="Sync this playlist to the connected device"
                        IsVisible="{Binding ((vm:MainWindowViewModel)DataContext).CanSyncToIPod, RelativeSource={RelativeSource AncestorType=Window}}"
                        Command="{Binding ((vm:MainWindowViewModel)DataContext).SyncCurrentPlaylistToIPodCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <i:Icon Value="fa-solid fa-arrows-rotate" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="Sync" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Padding="12,6" Cursor="Hand"
                        ToolTip.Tip="Burn this playlist to an audio CD"
                        IsVisible="{Binding ((vm:MainWindowViewModel)DataContext).IsBurnerPresent, RelativeSource={RelativeSource AncestorType=Window}}"
                        Command="{Binding ((vm:MainWindowViewModel)DataContext).BurnCurrentViewCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <i:Icon Value="fa-solid fa-circle-radiation" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="Burn Disc…" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </controls:MediaHeaderBar.Actions>

    </controls:MediaHeaderBar>

</UserControl>
