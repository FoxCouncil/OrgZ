#!/bin/sh
# Pre-commit gate: the full test suite must pass before any commit lands — no exceptions, no
# skips. This is the local mirror of the CI Tests workflow and the reason a coding harness (or a
# tired human) can't land a commit that breaks the product.
#
# Activate once per clone:   git config core.hooksPath .githooks
#
# Release configuration on purpose: a running Debug OrgZ.exe locks its own output and would block
# the build; Release stays isolated from the dev-run loop.

echo "pre-commit: running the test suite (Release)..."
dotnet test OrgZ.Tests/OrgZ.Tests.csproj -c Release --nologo
status=$?
if [ $status -ne 0 ]; then
    echo "pre-commit: TESTS FAILED (exit $status) - commit blocked." >&2
    exit $status
fi
echo "pre-commit: suite green - proceeding."
