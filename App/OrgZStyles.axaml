<Styles xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:b="using:OrgZ.Behaviors"
		xmlns:controls="using:OrgZ.Controls">

	<Styles.Resources>
		<!-- Override fluent DataGrid sort-icon reserved width: the default value
		     forces every header to reserve ~24px for the sort glyph even when
		     no sort is active, truncating headers in narrow columns. -->
		<x:Double x:Key="DataGridSortIconMinWidth">0</x:Double>

		<!-- Surfaces / chrome -->
		<Color x:Key="OrgZSurfaceDark">#1A1A1A</Color>
		<Color x:Key="OrgZInputBackground">#111111</Color>
		<Color x:Key="OrgZReadonlyBackground">#222222</Color>
		<Color x:Key="OrgZButtonBackground">#333333</Color>
		<Color x:Key="OrgZBorderColor">#444444</Color>
		<Color x:Key="OrgZBorderColorStrong">#555555</Color>
		<Color x:Key="OrgZFilterBarBackground">#1F0E0E</Color>
		<Color x:Key="OrgZPodcastSurface">#1A0F2E</Color>

		<!-- Text / accent -->
		<Color x:Key="OrgZTextForeground">#E0E0E0</Color>
		<Color x:Key="OrgZSubtitleText">#CCCCCC</Color>
		<Color x:Key="OrgZMutedText">#999999</Color>
		<Color x:Key="OrgZAccentBlue">#4A9EFF</Color>

		<!-- Tiles (podcast store / subscriptions) -->
		<Color x:Key="OrgZTileSurface">#222222</Color>
		<Color x:Key="OrgZTileBorder">#3F3F3F</Color>
		<Color x:Key="OrgZTileHoverOverlay">#22FFFFFF</Color>
		<Color x:Key="OrgZHeroOverlay">#CC000000</Color>
		<Color x:Key="OrgZAlbumArtBackdrop">#FFFFFF</Color>

		<!-- Status (success / warning / danger) -->
		<Color x:Key="OrgZSuccess">#7CFF7C</Color>
		<Color x:Key="OrgZWarning">#FFC07C</Color>
		<Color x:Key="OrgZDangerBorder">#663333</Color>
		<Color x:Key="OrgZDangerText">#FF8888</Color>
		<Color x:Key="OrgZError">#FF4500</Color>

		<!-- Disk-usage meter (DeviceInfoBar) -->
		<Color x:Key="OrgZDiskMeterTrack">#2A2A2A</Color>
		<Color x:Key="OrgZDiskMeterTrackBorder">#3A3A3A</Color>
		<Color x:Key="OrgZDiskMeterDivider">#444444</Color>
		<Color x:Key="OrgZDiskUsedStart">#6FB4FF</Color>
		<Color x:Key="OrgZDiskUsedEnd">#2F7EE5</Color>
		<Color x:Key="OrgZDiskFreeStart">#A0A0A0</Color>
		<Color x:Key="OrgZDiskFreeEnd">#606060</Color>

		<!-- Mini-player chrome: brushed-metal buttons + macOS stoplights -->
		<Color x:Key="OrgZMetalButtonBorder">#5A5A5A</Color>
		<Color x:Key="OrgZMetalButtonBorderActive">#7B7B7B</Color>
		<Color x:Key="OrgZMetalButtonHover">#D8D8D8</Color>
		<Color x:Key="OrgZStoplightCloseBorder">#9C2727</Color>
		<Color x:Key="OrgZStoplightCloseStart">#FF7B6C</Color>
		<Color x:Key="OrgZStoplightCloseEnd">#D6423A</Color>
		<Color x:Key="OrgZStoplightMinBorder">#A26A10</Color>
		<Color x:Key="OrgZStoplightMinStart">#FFD17A</Color>
		<Color x:Key="OrgZStoplightMinEnd">#E2A522</Color>
		<Color x:Key="OrgZStoplightMaxBorder">#1F8A26</Color>
		<Color x:Key="OrgZStoplightMaxStart">#72E580</Color>
		<Color x:Key="OrgZStoplightMaxEnd">#32B247</Color>

		<!-- LCD toggle-button states -->
		<Color x:Key="OrgZLcdButtonBackground">#B0B69E</Color>
		<Color x:Key="OrgZLcdButtonBackgroundActive">#6B7160</Color>

		<!-- iTunes-style carousel widget (PodcastsCarousel): deep purple chrome
		     around a dark inner card with a slightly lighter header strip.
		     Tuned for the OrgZ dark theme - the original iTunes cartouche was
		     white-on-light; this is its dark-mode cousin. -->
		<Color x:Key="OrgZCarouselOuter">#3D1F66</Color>
		<Color x:Key="OrgZCarouselButton">#7A3FD6</Color>
		<Color x:Key="OrgZCarouselSurface">#000000</Color>
		<Color x:Key="OrgZCarouselHeader">#2A1845</Color>
		<Color x:Key="OrgZCarouselHeaderHighlight">#463572</Color>
		<Color x:Key="OrgZCarouselDivider">#3D2F5C</Color>
		<Color x:Key="OrgZCarouselText">#E0E0E0</Color>
		<Color x:Key="OrgZCarouselSubtext">#999999</Color>
		<Color x:Key="OrgZCarouselDotActive">#C7B8E0</Color>
		<Color x:Key="OrgZCarouselDotInactive">#5B4880</Color>

		<!-- Brushes -->
		<SolidColorBrush x:Key="OrgZSurfaceDarkBrush" Color="{StaticResource OrgZSurfaceDark}" />
		<SolidColorBrush x:Key="OrgZInputBackgroundBrush" Color="{StaticResource OrgZInputBackground}" />
		<SolidColorBrush x:Key="OrgZReadonlyBackgroundBrush" Color="{StaticResource OrgZReadonlyBackground}" />
		<SolidColorBrush x:Key="OrgZButtonBackgroundBrush" Color="{StaticResource OrgZButtonBackground}" />
		<SolidColorBrush x:Key="OrgZBorderColorBrush" Color="{StaticResource OrgZBorderColor}" />
		<SolidColorBrush x:Key="OrgZBorderColorStrongBrush" Color="{StaticResource OrgZBorderColorStrong}" />
		<SolidColorBrush x:Key="OrgZFilterBarBackgroundBrush" Color="{StaticResource OrgZFilterBarBackground}" />
		<SolidColorBrush x:Key="OrgZPodcastSurfaceBrush" Color="{StaticResource OrgZPodcastSurface}" />
		<SolidColorBrush x:Key="OrgZTextForegroundBrush" Color="{StaticResource OrgZTextForeground}" />
		<SolidColorBrush x:Key="OrgZSubtitleTextBrush" Color="{StaticResource OrgZSubtitleText}" />
		<SolidColorBrush x:Key="OrgZMutedTextBrush" Color="{StaticResource OrgZMutedText}" />
		<SolidColorBrush x:Key="OrgZAccentBlueBrush" Color="{StaticResource OrgZAccentBlue}" />
		<SolidColorBrush x:Key="OrgZTileSurfaceBrush" Color="{StaticResource OrgZTileSurface}" />
		<SolidColorBrush x:Key="OrgZTileBorderBrush" Color="{StaticResource OrgZTileBorder}" />
		<SolidColorBrush x:Key="OrgZTileHoverOverlayBrush" Color="{StaticResource OrgZTileHoverOverlay}" />
		<SolidColorBrush x:Key="OrgZHeroOverlayBrush" Color="{StaticResource OrgZHeroOverlay}" />
		<SolidColorBrush x:Key="OrgZAlbumArtBackdropBrush" Color="{StaticResource OrgZAlbumArtBackdrop}" />
		<SolidColorBrush x:Key="OrgZSuccessBrush" Color="{StaticResource OrgZSuccess}" />
		<SolidColorBrush x:Key="OrgZWarningBrush" Color="{StaticResource OrgZWarning}" />
		<SolidColorBrush x:Key="OrgZDangerBorderBrush" Color="{StaticResource OrgZDangerBorder}" />
		<SolidColorBrush x:Key="OrgZDangerTextBrush" Color="{StaticResource OrgZDangerText}" />
		<SolidColorBrush x:Key="OrgZErrorBrush" Color="{StaticResource OrgZError}" />
		<SolidColorBrush x:Key="OrgZDiskMeterTrackBrush" Color="{StaticResource OrgZDiskMeterTrack}" />
		<SolidColorBrush x:Key="OrgZDiskMeterTrackBorderBrush" Color="{StaticResource OrgZDiskMeterTrackBorder}" />
		<SolidColorBrush x:Key="OrgZDiskMeterDividerBrush" Color="{StaticResource OrgZDiskMeterDivider}" />
		<SolidColorBrush x:Key="OrgZMetalButtonBorderBrush" Color="{StaticResource OrgZMetalButtonBorder}" />
		<SolidColorBrush x:Key="OrgZMetalButtonBorderActiveBrush" Color="{StaticResource OrgZMetalButtonBorderActive}" />
		<SolidColorBrush x:Key="OrgZMetalButtonHoverBrush" Color="{StaticResource OrgZMetalButtonHover}" />
		<SolidColorBrush x:Key="OrgZStoplightCloseBorderBrush" Color="{StaticResource OrgZStoplightCloseBorder}" />
		<SolidColorBrush x:Key="OrgZStoplightMinBorderBrush" Color="{StaticResource OrgZStoplightMinBorder}" />
		<SolidColorBrush x:Key="OrgZStoplightMaxBorderBrush" Color="{StaticResource OrgZStoplightMaxBorder}" />
		<SolidColorBrush x:Key="OrgZLcdButtonBackgroundBrush" Color="{StaticResource OrgZLcdButtonBackground}" />
		<SolidColorBrush x:Key="OrgZLcdButtonBackgroundActiveBrush" Color="{StaticResource OrgZLcdButtonBackgroundActive}" />
		<SolidColorBrush x:Key="OrgZCarouselOuterBrush" Color="{StaticResource OrgZCarouselOuter}" />
		<SolidColorBrush x:Key="OrgZCarouselButtonBrush" Color="{StaticResource OrgZCarouselButton}" />
		<SolidColorBrush x:Key="OrgZCarouselSurfaceBrush" Color="{StaticResource OrgZCarouselSurface}" />
		<SolidColorBrush x:Key="OrgZCarouselHeaderBrush" Color="{StaticResource OrgZCarouselHeader}" />
		<!-- Glossy header strip: a quick fade from the highlight color at the
		     very top to the base header color below gives the iTunes-style
		     "light glancing off the top edge" shine. Used by PodcastsCarousel
		     and PodcastsCard so the strip is consistent across the section. -->
		<LinearGradientBrush x:Key="OrgZCarouselHeaderShineBrush" StartPoint="0%,0%" EndPoint="0%,100%">
			<GradientStop Offset="0" Color="{StaticResource OrgZCarouselHeaderHighlight}" />
			<GradientStop Offset="1" Color="{StaticResource OrgZCarouselHeader}" />
		</LinearGradientBrush>
		<SolidColorBrush x:Key="OrgZCarouselDividerBrush" Color="{StaticResource OrgZCarouselDivider}" />
		<SolidColorBrush x:Key="OrgZCarouselTextBrush" Color="{StaticResource OrgZCarouselText}" />
		<SolidColorBrush x:Key="OrgZCarouselSubtextBrush" Color="{StaticResource OrgZCarouselSubtext}" />
		<SolidColorBrush x:Key="OrgZCarouselDotActiveBrush" Color="{StaticResource OrgZCarouselDotActive}" />
		<SolidColorBrush x:Key="OrgZCarouselDotInactiveBrush" Color="{StaticResource OrgZCarouselDotInactive}" />

		<!-- Font -->
		<FontFamily x:Key="OrgZMonoFont">Consolas</FontFamily>

		<!-- Padding compensation for Consolas baseline offset in AccessText -->
		<Thickness x:Key="OrgZMonoContentPadding">11,7,11,4</Thickness>
		<Thickness x:Key="OrgZMonoCheckPadding">8,5,0,1</Thickness>
		<Thickness x:Key="OrgZMonoComboBoxPadding">12,7,12,4</Thickness>

		<!-- ═══ Classic-iTunes palette ═══ -->
		<!-- LCD display: sage-green gradient with darker rim, used by the mini-player
		     chassis and the main-window now-playing panel.  All numeric and text
		     colors derived from this one palette so the two windows stay in sync. -->
		<LinearGradientBrush x:Key="OrgZLcdBrush" StartPoint="0%,0%" EndPoint="0%,100%">
			<GradientStop Offset="0" Color="#D2DAC4" />
			<GradientStop Offset="0.5" Color="#C8D0B7" />
			<GradientStop Offset="1" Color="#B6BEA6" />
		</LinearGradientBrush>
		<SolidColorBrush x:Key="OrgZLcdRimBrush" Color="#8B917C" />
		<SolidColorBrush x:Key="OrgZLcdTextBrush" Color="#1E2014" />
		<SolidColorBrush x:Key="OrgZLcdMutedTextBrush" Color="#3A3E28" />
		<SolidColorBrush x:Key="OrgZLcdProgressBrush" Color="#4A5840" />
		<SolidColorBrush x:Key="OrgZLcdProgressTrackBrush" Color="#9BA189" />

		<!-- Brushed-metal chassis for the mini-player body -->
		<LinearGradientBrush x:Key="OrgZMetalBrush" StartPoint="0%,0%" EndPoint="0%,100%">
			<GradientStop Offset="0" Color="#DFDFDF" />
			<GradientStop Offset="0.5" Color="#CBCBCB" />
			<GradientStop Offset="1" Color="#A8A8A8" />
		</LinearGradientBrush>
		<SolidColorBrush x:Key="OrgZMetalRimBrush" Color="#7A7A7A" />
		<SolidColorBrush x:Key="OrgZMetalTextBrush" Color="#2B2B2B" />

		<!-- Glossy aqua transport button body -->
		<LinearGradientBrush x:Key="OrgZAquaBrush" StartPoint="0%,0%" EndPoint="0%,100%">
			<GradientStop Offset="0" Color="#6F6F6F" />
			<GradientStop Offset="0.45" Color="#2A2A2A" />
			<GradientStop Offset="0.55" Color="#101010" />
			<GradientStop Offset="1" Color="#3A3A3A" />
		</LinearGradientBrush>
	</Styles.Resources>

	<!-- Truncation tooltips: any TextBlock whose text is trimmed (CharacterEllipsis, etc.)
	     shows its full text on hover. No-ops when the text fits. The LCD opts out below -
	     it has its own scrolling display. -->
	<Style Selector="TextBlock">
		<Setter Property="(b:TruncationToolTip.Enabled)" Value="True" />
	</Style>
	<Style Selector="controls|LcdDisplay TextBlock">
		<Setter Property="(b:TruncationToolTip.Enabled)" Value="False" />
	</Style>

	<!-- Dialog window background -->
	<Style Selector="Window.orgzDialog">
		<Setter Property="Background" Value="{StaticResource OrgZSurfaceDarkBrush}" />
	</Style>

	<!-- TextBlock -->
	<Style Selector="Window.orgzDialog TextBlock">
		<Setter Property="FontFamily" Value="{StaticResource OrgZMonoFont}" />
		<Setter Property="Foreground" Value="{StaticResource OrgZTextForegroundBrush}" />
	</Style>

	<!-- TextBox -->
	<Style Selector="Window.orgzDialog TextBox">
		<Setter Property="FontFamily" Value="{StaticResource OrgZMonoFont}" />
		<Setter Property="Background" Value="{StaticResource OrgZInputBackgroundBrush}" />
		<Setter Property="BorderBrush" Value="{StaticResource OrgZBorderColorBrush}" />
		<Setter Property="Foreground" Value="{StaticResource OrgZTextForegroundBrush}" />
	</Style>

	<!-- TextBox readonly -->
	<Style Selector="Window.orgzDialog TextBox:readonly">
		<Setter Property="Background" Value="{StaticResource OrgZReadonlyBackgroundBrush}" />
		<Setter Property="Foreground" Value="{StaticResource OrgZMutedTextBrush}" />
	</Style>

	<!-- CheckBox -->
	<Style Selector="Window.orgzDialog CheckBox">
		<Setter Property="FontFamily" Value="{StaticResource OrgZMonoFont}" />
		<Setter Property="Foreground" Value="{StaticResource OrgZTextForegroundBrush}" />
		<Setter Property="Padding" Value="{StaticResource OrgZMonoCheckPadding}" />
	</Style>

	<!-- RadioButton -->
	<Style Selector="Window.orgzDialog RadioButton">
		<Setter Property="FontFamily" Value="{StaticResource OrgZMonoFont}" />
		<Setter Property="Foreground" Value="{StaticResource OrgZTextForegroundBrush}" />
		<Setter Property="Padding" Value="{StaticResource OrgZMonoCheckPadding}" />
	</Style>

	<!-- ComboBox -->
	<Style Selector="Window.orgzDialog ComboBox">
		<Setter Property="FontFamily" Value="{StaticResource OrgZMonoFont}" />
		<Setter Property="Padding" Value="{StaticResource OrgZMonoComboBoxPadding}" />
	</Style>

	<!-- Button -->
	<Style Selector="Window.orgzDialog Button">
		<Setter Property="FontFamily" Value="{StaticResource OrgZMonoFont}" />
		<Setter Property="Background" Value="{StaticResource OrgZButtonBackgroundBrush}" />
		<Setter Property="Foreground" Value="{StaticResource OrgZTextForegroundBrush}" />
		<Setter Property="Padding" Value="{StaticResource OrgZMonoContentPadding}" />
	</Style>

	<!-- TabItem -->
	<Style Selector="Window.orgzDialog TabItem">
		<Setter Property="FontFamily" Value="{StaticResource OrgZMonoFont}" />
	</Style>

	<!-- Slider -->
	<Style Selector="Window.orgzDialog Slider">
		<Setter Property="Foreground" Value="{StaticResource OrgZAccentBlueBrush}" />
	</Style>

	<!-- Link button -->
	<Style Selector="Window.orgzDialog Button.link">
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="Padding" Value="0" />
		<Setter Property="Cursor" Value="Hand" />
		<Setter Property="Foreground" Value="{StaticResource OrgZAccentBlueBrush}" />
	</Style>
	<Style Selector="Window.orgzDialog Button.link:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="Transparent" />
	</Style>

	<!-- ListBox (for MessageLogDialog pattern) -->
	<Style Selector="Window.orgzDialog ListBox">
		<Setter Property="Background" Value="{StaticResource OrgZInputBackgroundBrush}" />
		<Setter Property="BorderBrush" Value="{StaticResource OrgZButtonBackgroundBrush}" />
		<Setter Property="BorderThickness" Value="1" />
	</Style>

	<!-- ContextMenu + MenuItem - Consolas with baseline padding fix -->
	<Style Selector="ContextMenu">
		<Setter Property="FontFamily" Value="{StaticResource OrgZMonoFont}" />
	</Style>
	<Style Selector="MenuItem">
		<Setter Property="FontFamily" Value="{StaticResource OrgZMonoFont}" />
		<Setter Property="Padding" Value="{StaticResource OrgZMonoContentPadding}" />
	</Style>

	<!-- Menu (non-native platform menus) -->
	<Style Selector="Menu">
		<Setter Property="FontFamily" Value="{StaticResource OrgZMonoFont}" />
	</Style>

	<!-- ===== iTunes-style LCD seek bar ===== =================================
	     Shared between MainWindow and MiniPlayerWindow. The 1px frame is a
	     sibling Border in the layout; this style handles the track + diamond
	     thumb. Foreground == Background so the elapsed (decrease) and remaining
	     (increase) halves render identically - only the diamond shows progress. -->
	<Style Selector="Slider.lcdSeek">
		<Setter Property="Background" Value="{StaticResource OrgZLcdBrush}" />
		<Setter Property="Foreground" Value="{StaticResource OrgZLcdBrush}" />
		<Setter Property="Margin" Value="0" />
	</Style>
	<Style Selector="Slider.lcdSeek /template/ Track#PART_Track">
		<Setter Property="Height" Value="12" />
	</Style>
	<!-- Collapse the Fluent RepeatButton (decrease/increase track halves) so
	     it renders nothing but its Background. The /template/ selector is
	     required because the RepeatButton lives in the Slider's template -
	     flat descendant selectors don't penetrate templates in Avalonia 12. -->
	<Style Selector="Slider.lcdSeek /template/ RepeatButton">
		<Setter Property="Padding" Value="0" />
		<Setter Property="MinWidth" Value="0" />
		<Setter Property="MinHeight" Value="0" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="Margin" Value="0" />
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="Template">
			<ControlTemplate>
				<Border Background="{TemplateBinding Background}" />
			</ControlTemplate>
		</Setter>
	</Style>
	<Style Selector="Slider.lcdSeek /template/ RepeatButton:pointerover">
		<Setter Property="Background" Value="Transparent" />
	</Style>
	<Style Selector="Slider.lcdSeek /template/ RepeatButton:pressed">
		<Setter Property="Background" Value="Transparent" />
	</Style>
	<!-- Diamond thumb. The Template + transparent chrome come from the style;
	     the Thumb's own Margin (1px top, sits the diamond inside the frame)
	     is set as a local value from code-behind in LcdDisplay.TemplateApplied,
	     because the Track's manual arrange ignores Style-set Margin on the
	     Thumb. -->
	<Style Selector="Slider.lcdSeek /template/ Thumb#thumb">
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="BorderBrush" Value="Transparent" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="Template">
			<ControlTemplate>
				<Path Width="11" Height="11" Margin="0,3,0,0"
				      HorizontalAlignment="Center" VerticalAlignment="Top"
				      Stretch="Fill" Fill="{StaticResource OrgZLcdTextBrush}"
				      Data="M 6,0 L 12,6 L 6,12 L 0,6 Z" />
			</ControlTemplate>
		</Setter>
	</Style>

	<!-- Round LCD-toggle button (used to flip the track info / VU meter inside
	     the LCD display of both mini-player and main-window now-playing).
	     Visually stable: no hover tint, no press dent - only the icon glyph
	     inside swaps to reflect state. -->
	<Style Selector="Button.lcdToggle">
		<Setter Property="Width" Value="20" />
		<Setter Property="Height" Value="20" />
		<Setter Property="CornerRadius" Value="10" />
		<Setter Property="Padding" Value="0" />
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="BorderBrush" Value="{StaticResource OrgZLcdTextBrush}" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="Cursor" Value="Hand" />
		<Setter Property="HorizontalContentAlignment" Value="Center" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
	</Style>
	<Style Selector="Button.lcdToggle:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="BorderBrush" Value="{StaticResource OrgZLcdTextBrush}" />
	</Style>
	<Style Selector="Button.lcdToggle:pressed /template/ ContentPresenter">
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="BorderBrush" Value="{StaticResource OrgZLcdTextBrush}" />
	</Style>

	<!-- DataGrid column headers: fluent default uses Padding="12,0,0,0" (left-only),
	     which leaves header text flush against the right edge with no room for
	     ellipsis when a column is narrow. Symmetric padding + min-height for breathing room.
	     HorizontalContentAlignment=Stretch is critical: the template binds its inner
	     Grid alignment to that, and the default (Left) makes the content size to
	     text only instead of filling the column width. -->
	<Style Selector="DataGridColumnHeader">
		<Setter Property="Padding" Value="8,4" />
		<Setter Property="MinHeight" Value="28" />
		<Setter Property="HorizontalContentAlignment" Value="Stretch" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
	</Style>
</Styles>
